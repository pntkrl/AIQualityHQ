---
// src/pages/how-it-was-built.astro
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Button from '../components/ui/Button.astro';
import { Layers, Zap, Globe, Palette, Code, Server, ArrowRight, ExternalLink, CheckCircle2 } from '@lucide/astro';

const title = "How It Was Built — Tech Stack & Resources | AIQualityHQ";
const description = "Discover the tools, frameworks, and resources used to build AIQualityHQ. Everything you need to know about our tech stack.";

const tools = [
  {
    category: "Framework & Frontend",
    items: [
      {
        name: "Astro",
        description: "The all-in-one web framework designed for speed. We use Astro to ship zero JavaScript by default, ensuring blazing fast load times and perfect SEO.",
        icon: Zap,
        color: "text-orange-500",
        bg: "bg-orange-500/10",
        link: "https://astro.build",
        cta: "Try Astro for Free"
      },
      {
        name: "Tailwind CSS",
        description: "A utility-first CSS framework that allowed us to build our custom design system and premium UI components rapidly without ever leaving our HTML.",
        icon: Palette,
        color: "text-cyan-500",
        bg: "bg-cyan-500/10",
        link: "https://tailwindcss.com",
        cta: "Build with Tailwind"
      }
    ]
  },
  {
    category: "Hosting & Infrastructure",
    items: [
      {
        name: "Cloudflare Pages",
        description: "We deploy our Astro site to Cloudflare's edge network. This provides instant global caching, built-in CI/CD, and unbeatable performance.",
        icon: Globe,
        color: "text-amber-500",
        bg: "bg-amber-500/10",
        link: "https://pages.cloudflare.com",
        cta: "Host on Cloudflare"
      },
      {
        name: "Hostinger",
        description: "Secure, reliable, and incredibly affordable domain registration and hosting to ensure our brand is protected and accessible worldwide.",
        icon: Server,
        color: "text-indigo-500",
        bg: "bg-indigo-500/10",
        link: "https://www.hostinger.com/in?REFERRALCODE=UDVKRALIALRV",
        cta: "Get Hostinger Deal"
      }
    ]
  },
  {
    category: "AI & APIs",
    items: [
      {
        name: "OpenRouter",
        description: "The unified AI API that powers our prompt checker and auditor. It gives us instant access to the best LLMs (like GPT-4 and Claude) with a single interface.",
        icon: Code,
        color: "text-emerald-500",
        bg: "bg-emerald-500/10",
        link: "https://openrouter.ai",
        cta: "Try OpenRouter API"
      }
    ]
  }
];
---

<MarketingLayout title={title} description={description}>
  <Header activeNav="resources" />

  <main class="flex-grow pt-24 pb-20">
    <!-- Hero Section -->
    <section class="max-w-[1200px] mx-auto px-6 mb-20 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-sm font-medium mb-6">
        <Layers class="w-4 h-4" />
        <span>Tech Stack & Resources</span>
      </div>
      
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-text-primary mb-6">
        How We Built <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-primary-hover">AIQualityHQ</span>
      </h1>
      
      <p class="text-lg md:text-xl text-text-secondary max-w-[800px] mx-auto leading-relaxed">
        Transparency is core to our mission. Explore the exact frameworks, hosting platforms, and AI APIs we use to deliver a lightning-fast, premium experience to our users.
      </p>
    </section>

    <!-- Complete Workflow Tutorial -->
    <section class="max-w-[1000px] mx-auto px-6 mb-24">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold tracking-tight text-text-primary mb-4">
          The Complete Workflow
        </h2>
        <p class="text-lg text-text-secondary">
          A transparent look at exactly how this platform was built, from idea to monetization.
        </p>
      </div>

      <div class="relative border-l border-border-subtle ml-4 md:ml-8 space-y-12 pb-8">
        <!-- Step 1 -->
        <div class="relative pl-8 md:pl-12">
          <div class="absolute -left-3.5 md:-left-4 top-1 w-7 h-7 md:w-8 md:h-8 rounded-full bg-surface border-2 border-primary text-primary flex items-center justify-center">
            <span class="text-xs md:text-sm font-bold">1</span>
          </div>
          <h3 class="text-xl font-bold text-text-primary mb-2 flex items-center gap-2">
            Laying the Foundation <CheckCircle2 class="w-5 h-5 text-emerald-500" />
          </h3>
          <p class="text-text-secondary leading-relaxed mb-4">
            Every great project starts with securing a brand identity and reliable hosting. We used Hostinger to register the domain and lock in the infrastructure because of its unmatched speed-to-cost ratio. 
          </p>
          <div class="bg-surface-secondary border border-border-subtle p-4 rounded-xl">
            <p class="text-sm text-text-secondary mb-3"><strong class="text-text-primary">Monetization Tip:</strong> This is our first affiliate touchpoint. If you're building a tool, recommend the infrastructure you actually use.</p>
            <a href="https://www.hostinger.com/in?REFERRALCODE=UDVKRALIALRV" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-sm font-medium text-primary hover:text-primary-hover group">
              Get the same Hostinger deal we used <ArrowRight class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1" />
            </a>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="relative pl-8 md:pl-12">
          <div class="absolute -left-3.5 md:-left-4 top-1 w-7 h-7 md:w-8 md:h-8 rounded-full bg-surface border-2 border-primary text-primary flex items-center justify-center">
            <span class="text-xs md:text-sm font-bold">2</span>
          </div>
          <h3 class="text-xl font-bold text-text-primary mb-2">Building for Speed</h3>
          <p class="text-text-secondary leading-relaxed">
            To ensure the site ranks well on Google, it has to be fast. We built the frontend using <strong>Astro</strong> to ship zero JavaScript by default, styled entirely with <strong>Tailwind CSS</strong> to maintain a premium, glassmorphism design system without heavy CSS bundles.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="relative pl-8 md:pl-12">
          <div class="absolute -left-3.5 md:-left-4 top-1 w-7 h-7 md:w-8 md:h-8 rounded-full bg-surface border-2 border-primary text-primary flex items-center justify-center">
            <span class="text-xs md:text-sm font-bold">3</span>
          </div>
          <h3 class="text-xl font-bold text-text-primary mb-2">Engineering the AI Logic</h3>
          <p class="text-text-secondary leading-relaxed">
            The core value of AIQualityHQ is the Prompt Checker and Auditor. Instead of locking into a single provider, we integrated the <strong>OpenRouter API</strong>. This unified interface allows the tool to route requests to the best available LLMs (like GPT-4 and Claude 3.5 Sonnet) seamlessly.
          </p>
        </div>

        <!-- Step 4 -->
        <div class="relative pl-8 md:pl-12">
          <div class="absolute -left-3.5 md:-left-4 top-1 w-7 h-7 md:w-8 md:h-8 rounded-full bg-surface border-2 border-primary text-primary flex items-center justify-center">
            <span class="text-xs md:text-sm font-bold">4</span>
          </div>
          <h3 class="text-xl font-bold text-text-primary mb-2">Global Edge Deployment</h3>
          <p class="text-text-secondary leading-relaxed">
            Once the code was complete, we pushed it to GitHub and connected it to <strong>Cloudflare Pages</strong>. Cloudflare automatically builds the Astro site and distributes it across their global edge network, resulting in near-instant load times for users anywhere in the world.
          </p>
        </div>

        <!-- Step 5 -->
        <div class="relative pl-8 md:pl-12">
          <div class="absolute -left-3.5 md:-left-4 top-1 w-7 h-7 md:w-8 md:h-8 rounded-full bg-surface border-2 border-primary text-primary flex items-center justify-center">
            <span class="text-xs md:text-sm font-bold">5</span>
          </div>
          <h3 class="text-xl font-bold text-text-primary mb-2 flex items-center gap-2">
            Delivering Value & Monetization <Zap class="w-5 h-5 text-amber-500" />
          </h3>
          <p class="text-text-secondary leading-relaxed mb-4">
            The strategy is simple: give away an incredibly valuable, high-quality tool for free. This builds immense trust and drives organic traffic. We then monetize transparently by recommending the exact tools we used to build the platform.
          </p>
        </div>
      </div>
    </section>

    <!-- Stack Grid -->
    <section class="max-w-[1200px] mx-auto px-6">
      <div class="flex flex-col gap-16">
        {tools.map((section) => (
          <div>
            <h2 class="text-2xl font-semibold tracking-tight text-text-primary mb-8 pb-4 border-b border-border-subtle">
              {section.category}
            </h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {section.items.map((tool) => (
                <div class="group relative bg-surface border border-border-subtle rounded-2xl p-8 hover:border-primary/50 transition-all duration-300 hover:shadow-[0_8px_30px_rgb(0,0,0,0.04)] dark:hover:shadow-[0_8px_30px_rgba(255,255,255,0.04)] overflow-hidden">
                  
                  <!-- Glassmorphism gradient effect on hover -->
                  <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
                  
                  <div class="relative z-10 flex flex-col h-full">
                    <div class="flex items-center gap-4 mb-6">
                      <div class={`w-12 h-12 rounded-xl flex items-center justify-center ${tool.bg} ${tool.color}`}>
                        <tool.icon class="w-6 h-6" />
                      </div>
                      <h3 class="text-xl font-bold text-text-primary">
                        {tool.name}
                      </h3>
                    </div>
                    
                    <p class="text-text-secondary leading-relaxed mb-8 flex-grow">
                      {tool.description}
                    </p>
                    
                    <div class="pt-6 border-t border-border-subtle mt-auto">
                      <a 
                        href={tool.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center justify-between w-full px-6 py-3 rounded-lg bg-text-primary text-canvas hover:bg-text-secondary transition-fast font-medium group/btn"
                      >
                        <span>{tool.cta}</span>
                        <ExternalLink class="w-4 h-4 transition-transform group-hover/btn:translate-x-1" />
                      </a>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="max-w-[800px] mx-auto px-6 mt-32 text-center">
      <div class="bg-surface-secondary border border-border-subtle rounded-3xl p-10 md:p-16 relative overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-primary/10 via-transparent to-transparent opacity-50"></div>
        <div class="relative z-10">
          <h2 class="text-3xl font-bold text-text-primary mb-4">Want to build something similar?</h2>
          <p class="text-text-secondary mb-8 max-w-[600px] mx-auto">
            These are the exact tools we use in production every day. Start your own project using the resources above to ensure maximum performance and scalability.
          </p>
          <div class="flex justify-center">
            <Button href="/" variant="primary" size="lg" class="group">
              Return to Homepage
              <ArrowRight class="w-4 h-4 ml-2 transition-transform group-hover:translate-x-1" />
            </Button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</MarketingLayout>
