---
// src/pages/checker.astro
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import CheckerWorkspace from '../components/dashboard/CheckerWorkspace';
import { ShieldCheck, Zap, Brain, TrendingUp } from '@lucide/astro';
import Button from '../components/ui/Button.astro';

const siteUrl = "https://aiqualityhq.com";

const pageTitle = "Free AI Prompt Checker";
const pageDescription = "Check and improve AI prompts with our free prompt checker. Analyze quality across six dimensions — structure, clarity, safety, and more.";
const canonicalUrl = `${siteUrl}/checker`;
const ogImage = `${siteUrl}/og-checker.png`;

const softwareSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "AIQualityHQ Prompt Checker",
      "description": pageDescription,
      "url": canonicalUrl,
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Web",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "AIQualityHQ"
      },
      "featureList": "Six-Dimension Scoring, Instant Analysis, Privacy-First Architecture, Actionable Fix Suggestions, Diff View, Export Results"
    },
    {
      "@type": "WebSite",
      "name": "AIQualityHQ",
      "url": siteUrl,
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": `${siteUrl}/search?q={search_term_string}`
        },
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "Organization",
      "name": "AIQualityHQ",
      "url": siteUrl,
      "logo": `${siteUrl}/aiqualityhq-logo.png`
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": siteUrl
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Free AI Prompt Checker",
          "item": canonicalUrl
        }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a prompt checker?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A prompt checker is a tool that analyzes AI prompt text to evaluate its quality across dimensions like structure, clarity, safety, and effectiveness. It helps identify weaknesses and provides suggestions for improvement."
          }
        },
        {
          "@type": "Question",
          "name": "How does an AI prompt checker work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An AI prompt checker uses deterministic rules and quality engine analysis to scan your prompt for structure, persona bindings, context boundaries, safety filters, and more. It scores each dimension and generates a detailed report with actionable optimization suggestions."
          }
        },
        {
          "@type": "Question",
          "name": "Is this prompt checker free?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, the AIQualityHQ prompt checker is completely free to use. You can check unlimited prompts, view detailed scores across six quality dimensions, and get optimization suggestions without any cost."
          }
        },
        {
          "@type": "Question",
          "name": "What dimensions does the prompt checker evaluate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The prompt checker evaluates six core dimensions: Prompt Structure, Memory & State management, Context Grounding, Trust & Accuracy, PII & Privacy, and Security & Safety. Each dimension receives a score with specific pass/fail rule details."
          }
        },
        {
          "@type": "Question",
          "name": "Why should I check my AI prompts?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Checking your AI prompts helps ensure consistent output quality, identify security vulnerabilities like prompt injection, verify privacy compliance, and optimize prompt structure for better AI model responses. It is essential for production-grade AI applications."
          }
        }
      ]
    }
  ]
};
---

<MarketingLayout title={pageTitle} description={pageDescription} canonicalUrl={canonicalUrl} image={ogImage}>
  <!-- Sticky Header Navigation -->
  <Header activeNav="checker" />

  <main class="flex-grow py-12 px-6">
    <div class="max-w-[1200px] mx-auto flex flex-col gap-8">
      <!-- Hostinger Referral Promo Banner -->
      <div class="relative overflow-hidden rounded-2xl border border-border bg-surface-secondary/20 p-6 md:p-8 flex flex-col md:flex-row items-center justify-between gap-6 transition-default hover:border-primary-border/60 hover:bg-surface-secondary/30">
        <!-- Glow background effect -->
        <div class="absolute -top-24 -right-24 w-48 h-48 rounded-full bg-primary/10 blur-3xl pointer-events-none" aria-hidden="true"></div>
        
        <div class="flex-grow max-w-2xl text-left relative z-10">
          <span class="inline-flex items-center gap-1 font-mono text-[10px] font-semibold uppercase tracking-widest text-primary mb-2 bg-primary-subtle px-2.5 py-0.5 rounded-full select-none">
            Recommended Hosting
          </span>
          <h3 class="text-lg md:text-xl font-semibold tracking-tight text-text-primary text-pretty">
            How We Launched AIQualityHQ
          </h3>
          <p class="mt-2 text-xs md:text-sm text-text-secondary leading-relaxed">
            We registered our domain on Hostinger. Start your own project using our referral link and get a custom domain for free with any 1-year hosting plan.
          </p>
        </div>
        <div class="shrink-0 w-full md:w-auto relative z-10">
          <Button 
            href="https://www.hostinger.com/in?REFERRALCODE=UDVKRALIALRV" 
            target="_blank" 
            rel="noopener noreferrer" 
            variant="primary" 
            size="md"
            class="w-full md:w-auto text-center"
          >
            Claim Free Domain
          </Button>
        </div>
      </div>

      <!-- Page Header -->
      <div class="border-b border-border-subtle pb-6">
        <div class="flex items-center gap-2 text-primary font-mono text-xs uppercase tracking-wider mb-2">
          <ShieldCheck class="w-4 h-4" />
          <span>Free AI Prompt Checker</span>
        </div>
        <h1 class="text-3xl font-semibold tracking-tight text-text-primary">
          Free AI Prompt Checker — Analyze & Score Your Prompts
        </h1>
        <p class="text-sm text-text-secondary mt-1.5 max-w-2xl leading-relaxed">
          Use our free online prompt checker to evaluate and improve your AI prompts. The AIQualityHQ Quality Engine scans prompt syntax, structure, and safety in under 10 milliseconds, scoring across six core dimensions with actionable fix suggestions.
        </p>
      </div>

      <!-- Hydrated Interactive React Workspace Island -->
      <CheckerWorkspace client:load />

      <!-- Features Section -->
      <section>
        <h2 class="sr-only">Prompt Checker Features</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 pt-4">
        <div class="flex items-start gap-3">
          <Zap class="w-5 h-5 text-primary mt-0.5 shrink-0" />
          <div>
            <h3 class="text-sm font-semibold text-text-primary">Instant Analysis</h3>
            <p class="text-xs text-text-secondary mt-0.5">Get prompt quality scores in milliseconds with our local deterministic engine. No API key required.</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <TrendingUp class="w-5 h-5 text-primary mt-0.5 shrink-0" />
          <div>
            <h3 class="text-sm font-semibold text-text-primary">Six-Dimension Scoring</h3>
            <p class="text-xs text-text-secondary mt-0.5">Evaluate structure, memory, context, accuracy, privacy, and safety with detailed pass/fail rules per dimension.</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <Brain class="w-5 h-5 text-primary mt-0.5 shrink-0" />
          <div>
            <h3 class="text-sm font-semibold text-text-primary">Actionable Fixes</h3>
            <p class="text-xs text-text-secondary mt-0.5">Receive specific optimization suggestions and a fix checklist to improve your prompts for production use.</p>
          </div>
        </div>
      </div>
      </section>

      <!-- FAQ Section -->
      <div class="border-t border-border-subtle pt-8 mt-4">
        <h2 class="text-xl font-semibold tracking-tight text-text-primary mb-6">
          How the Prompt Checker Works
        </h2>
        <div class="space-y-6">
          <div>
            <h3 class="text-sm font-semibold text-text-primary">What happens when I click Analyze?</h3>
            <p class="text-xs text-text-secondary mt-1 leading-relaxed">When you click Analyze, the Quality Engine parses your prompt text locally in your browser. It runs deterministic rules across six dimensions — checking for role definitions, context boundaries, output format specifications, PII patterns, injection vectors, and more. Results appear in under 10 milliseconds with a per-dimension score breakdown and specific pass/fail diagnostics.</p>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-text-primary">Can I check multiple prompts in one session?</h3>
            <p class="text-xs text-text-secondary mt-1 leading-relaxed">Yes. You can analyze as many prompts as you want in a single session. Each analysis is independent and runs instantly. Your analysis history is stored in your browser's local storage so you can compare scores across different prompt revisions without creating an account.</p>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-text-primary">What do the six dimension scores mean?</h3>
            <p class="text-xs text-text-secondary mt-1 leading-relaxed">Each dimension scores from 0 to 100 based on specific pass/fail rules. Prompt Structure checks formatting and role clarity. Memory & State evaluates context management. Context Grounding measures reference usage. Trust & Accuracy flags hallucination risks. PII & Privacy detects data exposure. Security & Safety scans for injection attacks. The overall score is a weighted average with Trust & Accuracy weighted highest at 25%.</p>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-text-primary">How do I improve a low score?</h3>
            <p class="text-xs text-text-secondary mt-1 leading-relaxed">Each failed rule includes a specific fix suggestion. Common improvements include adding a clear system role definition ("You are..."), specifying output format constraints (JSON, markdown, table), adding boundary delimiters between sections, and including explicit safety instructions. Apply the suggested fixes, re-analyze, and compare your before/after scores using the diff view.</p>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-text-primary">Does the checker work with any AI model's prompts?</h3>
            <p class="text-xs text-text-secondary mt-1 leading-relaxed">Yes. The Quality Engine evaluates prompt text structure and patterns regardless of which AI model you plan to use. It works with prompts designed for OpenAI GPT-4, Anthropic Claude, Google Gemini, Meta Llama, Mistral, and any other language model. The analysis focuses on universal prompt engineering best practices that improve output quality across all models.</p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- Global Footer -->
  <Footer />
</MarketingLayout>

<script type="application/ld+json" is:inline set:html={JSON.stringify(softwareSchema)}></script>
