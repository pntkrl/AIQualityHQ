---
// src/pages/login.astro
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import Input from '../components/ui/Input.astro';
import SocialLogin from '../components/auth/SocialLogin';
import { ShieldAlert } from '@lucide/astro';
import { OAUTH_CONFIG } from '../lib/social-auth';

const siteUrl = "https://aiqualityhq.com";
const pageTitle = "Log In";
const pageDescription = "Log in to your AIQualityHQ dashboard to view prompt analysis history, diagnostic reports, and quality performance trends across evaluations.";
---

<MarketingLayout title={pageTitle} description={pageDescription} canonicalUrl={`${siteUrl}/login`} noindex={true}>
  <Header />
  <main class="flex-grow flex flex-col items-center justify-center bg-canvas px-6 py-12 md:py-20">
    <div class="w-full max-w-[400px] flex flex-col gap-6">

      <!-- Login Card -->
      <Card class="p-6 md:p-8 flex flex-col gap-5">
        <div class="text-center">
          <h1 class="text-base font-semibold text-text-primary">Log in to your account</h1>
          <p class="text-xs text-text-secondary mt-1">Enter your details to access the dashboard</p>
        </div>

        <!-- Error Banner -->
        <div id="error-banner" class="hidden border border-error-subtle bg-error-subtle text-error p-3 rounded-lg flex items-start gap-2 text-xs font-sans">
          <ShieldAlert class="w-4 h-4 shrink-0 mt-0.5" />
          <span id="error-message">Invalid email or password.</span>
        </div>

        <!-- Form fields -->
        <form id="login-form" class="flex flex-col gap-4">
          <div class="flex flex-col gap-1.5">
            <label for="login-email" class="text-[10px] font-mono font-semibold uppercase tracking-wider text-text-secondary">Email</label>
            <Input type="email" id="login-email" name="email" placeholder="name@company.com" required />
          </div>
          <div class="flex flex-col gap-1.5">
            <div class="flex justify-between items-center">
              <label for="login-password" class="text-[10px] font-mono font-semibold uppercase tracking-wider text-text-secondary">Password</label>
              <a href="#" class="text-[10px] text-text-tertiary hover:text-primary transition-fast font-sans" onclick="alert('Demo password is: demo123')">Forgot password?</a>
            </div>
            <Input type="password" id="login-password" name="password" placeholder="••••••••" required />
          </div>
          <Button type="submit" variant="primary" class="w-full mt-2 h-10 select-none">
            Log In
          </Button>
        </form>

        <SocialLogin googleClientId={OAUTH_CONFIG.googleClientId} client:load />

        <div class="text-center pt-3 border-t border-border-subtle mt-1">
          <p class="text-xs text-text-secondary font-sans">
            Don't have an account? 
            <a href="/signup" class="text-primary hover:text-primary-hover font-semibold underline underline-offset-2 transition-fast ml-1">
              Sign up
            </a>
          </p>
        </div>
      </Card>

      <!-- Footer navigation -->
      <p class="text-center text-xs text-text-secondary font-sans">
        Don't have an account? 
        <a href="/signup" class="text-primary hover:text-primary-hover font-medium underline underline-offset-2 transition-fast">
          Sign up
        </a>
      </p>

    </div>

    <!-- SEO Content -->
    <section class="max-w-[600px] mx-auto mt-12 pt-8 border-t border-border-subtle">
      <h2 class="text-sm font-semibold text-text-primary mb-2">Why Log In to AIQualityHQ?</h2>
      <p class="text-xs text-text-secondary leading-relaxed mb-3">
        Your AIQualityHQ dashboard stores prompt analysis history, diagnostic reports, and quality performance trends. Track improvements across prompt revisions, compare scores between different prompt templates, and export detailed reports for team review.
      </p>
      <p class="text-xs text-text-secondary leading-relaxed mb-3">
        All analysis data stays in your browser. No prompt content is uploaded to any server. The dashboard simply organizes your local analysis results for easy reference and comparison.
      </p>
      <p class="text-xs text-text-secondary leading-relaxed">
        The quality scoring engine evaluates prompts across six dimensions: Prompt Structure, Memory and State, Context Grounding, Trust and Accuracy, PII and Privacy, and Security and Safety. Each dimension receives a score with detailed pass or fail rule explanations and specific optimization suggestions.
      </p>
    </section>
  </main>
  <Footer />
</MarketingLayout>

<script>
  const apiBase = window.location.origin + '/api';

  // Seed demo account in localStorage (fallback)
  const users = localStorage.getItem('aiq_users');
  if (!users) {
    localStorage.setItem('aiq_users', JSON.stringify([
      { email: 'demo@aiqualityhq.com', password: 'demo123' }
    ]));
  }

  const form = document.getElementById('login-form') as HTMLFormElement | null;
  const errorBanner = document.getElementById('error-banner');
  const errorMessage = document.getElementById('error-message');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const emailInput = document.getElementById('login-email') as HTMLInputElement;
      const passwordInput = document.getElementById('login-password') as HTMLInputElement;
      
      if (!emailInput || !passwordInput) return;

      const email = emailInput.value.trim();
      const password = passwordInput.value;

      // Try API login first
      try {
        const res = await fetch(`${apiBase}/auth/login`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password }),
        });

        if (res.ok) {
          const data = await res.json();
          localStorage.setItem('aiq_session_token', data.session.token);
          localStorage.setItem('user_session', JSON.stringify({
            email: data.user.email,
            name: data.user.name,
            id: data.user.id,
            timestamp: Date.now()
          }));
          window.location.href = '/dashboard';
          return;
        }

        // API returned error, try localStorage fallback
        const errData = await res.json().catch(() => ({}));
        if (res.status !== 404) {
          // API exists but returned error - use API error, not fallback
          if (errorBanner && errorMessage) {
            errorMessage.textContent = errData.error || 'Login failed. Please try again.';
            errorBanner.classList.remove('hidden');
          }
          return;
        }
        // 404 = API not deployed, fall through to localStorage
      } catch {
        // API unreachable, fall through to localStorage
      }

      // localStorage fallback
      const accountsList = JSON.parse(localStorage.getItem('aiq_users') || '[]');
      const matchedUser = accountsList.find(
        (u: any) => u.email.toLowerCase() === email.toLowerCase() && u.password === password
      );

      if (matchedUser) {
        localStorage.setItem('user_session', JSON.stringify({
          email: matchedUser.email,
          timestamp: Date.now()
        }));
        window.location.href = '/dashboard';
      } else {
        if (errorBanner && errorMessage) {
          errorMessage.textContent = "Invalid email or password.";
          errorBanner.classList.remove('hidden');
        }
      }
    });
  }
</script>
