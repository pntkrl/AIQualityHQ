---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import AIAuditConsole from '../components/dashboard/AIAuditConsole';
import { Sparkles, Bot, Shield, RefreshCw, Eye, GitBranch } from '@lucide/astro';
import Button from '../components/ui/Button.astro';

const siteUrl = "https://aiqualityhq.com";
const pageTitle = "AI Prompt Auditor";
const pageDescription = "Go beyond rule-based checks. Use AI to audit prompts across clarity, structure, context, safety, and formatting. Get detailed scores.";
const canonicalUrl = `${siteUrl}/ai-audit`;
const ogImage = `${siteUrl}/og-ai-audit.png`;

const auditSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "AIQualityHQ AI Prompt Auditor",
      "description": pageDescription,
      "url": canonicalUrl,
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Web",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "ratingCount": "128",
        "bestRating": "5",
        "worstRating": "1"
      },
      "author": { "@type": "Organization", "name": "AIQualityHQ" },
      "featureList": "AI-Powered Analysis, Multi-Provider Support, Clarity Scoring, Safety Evaluation, Context Assessment"
    },
    {
      "@type": "WebSite",
      "name": "AIQualityHQ",
      "url": siteUrl,
      "potentialAction": {
        "@type": "SearchAction",
        "target": { "@type": "EntryPoint", "urlTemplate": `${siteUrl}/search?q={search_term_string}` },
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "Organization",
      "name": "AIQualityHQ", "url": siteUrl, "logo": `${siteUrl}/aiqualityhq-logo.png`
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "AI Prompt Quality Auditor", "item": canonicalUrl }
      ]
    }
  ]
};
---

<MarketingLayout title={pageTitle} description={pageDescription} canonicalUrl={canonicalUrl} image={ogImage}>
  <Header activeNav="ai-audit" />

  <main class="flex-grow py-12 px-6">
    <div class="max-w-[1200px] mx-auto flex flex-col gap-8">
      <!-- Hostinger Referral Promo Banner -->
      <div class="relative overflow-hidden rounded-2xl border border-border bg-surface-secondary/20 p-6 md:p-8 flex flex-col md:flex-row items-center justify-between gap-6 transition-default hover:border-primary-border/60 hover:bg-surface-secondary/30">
        <!-- Glow background effect -->
        <div class="absolute -top-24 -right-24 w-48 h-48 rounded-full bg-primary/10 blur-3xl pointer-events-none" aria-hidden="true"></div>
        
        <div class="flex-grow max-w-2xl text-left relative z-10">
          <span class="inline-flex items-center gap-1 font-mono text-[10px] font-semibold uppercase tracking-widest text-primary mb-2 bg-primary-subtle px-2.5 py-0.5 rounded-full select-none">
            Recommended Hosting
          </span>
          <h3 class="text-lg md:text-xl font-semibold tracking-tight text-text-primary text-pretty">
            How We Launched AIQualityHQ
          </h3>
          <p class="mt-2 text-xs md:text-sm text-text-secondary leading-relaxed">
            We registered our domain on Hostinger. Start your own project using our referral link and get a custom domain for free with any 1-year hosting plan.
          </p>
        </div>
        <div class="shrink-0 w-full md:w-auto relative z-10">
          <Button 
            href="https://www.hostinger.com/in?REFERRALCODE=UDVKRALIALRV" 
            target="_blank" 
            rel="noopener noreferrer" 
            variant="primary" 
            size="md"
            class="w-full md:w-auto text-center"
          >
            Claim Free Domain
          </Button>
        </div>
      </div>

      <div class="border-b border-border-subtle pb-6">
        <div class="flex items-center gap-2 text-primary font-mono text-xs uppercase tracking-wider mb-2">
          <Sparkles class="w-4 h-4" />
          <span>AI-Powered Prompt Auditor</span>
        </div>
        <h1 class="text-3xl font-semibold tracking-tight text-text-primary">
          AI Prompt Quality Auditor — Deep Analysis with LLM Intelligence
        </h1>
        <p class="text-sm text-text-secondary mt-1.5 max-w-2xl leading-relaxed">
          Go beyond deterministic rules. The AI Auditor uses an LLM to analyze your prompt across clarity, structure, context, safety, and formatting — then generates an optimized version with detailed findings.
        </p>
      </div>

      <section>
        <h2 class="sr-only">AI-Powered Prompt Audit Tool</h2>
        <AIAuditConsole client:load />
      </section>

      <!-- How the AI Auditor Works -->
      <section class="border-t border-border-subtle pt-10">
        <div class="max-w-[720px]">
          <h2 class="text-xl font-semibold tracking-tight text-text-primary mb-4">How the AI Auditor Works</h2>
          <p class="text-sm text-text-secondary leading-relaxed mb-4">
            Unlike the deterministic Prompt Checker which applies fixed rules, the AI Auditor submits your prompt to an LLM with a structured audit system prompt. The model evaluates five quality dimensions and returns a scored report with specific findings.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <div class="border border-border bg-surface-secondary/40 rounded-lg p-4">
              <Eye class="w-5 h-5 text-primary mb-2" />
              <h3 class="text-sm font-semibold text-text-primary mb-1">Clarity Analysis</h3>
              <p class="text-xs text-text-secondary">Evaluates instruction specificity, ambiguity, and whether the prompt communicates intent clearly to the model.</p>
            </div>
            <div class="border border-border bg-surface-secondary/40 rounded-lg p-4">
              <Bot class="w-5 h-5 text-primary mb-2" />
              <h3 class="text-sm font-semibold text-text-primary mb-1">Structure Audit</h3>
              <p class="text-xs text-text-secondary">Checks for proper persona definitions, task boundaries, output formatting, and constraint declarations.</p>
            </div>
            <div class="border border-border bg-surface-secondary/40 rounded-lg p-4">
              <Shield class="w-5 h-5 text-primary mb-2" />
              <h3 class="text-sm font-semibold text-text-primary mb-1">Safety Scan</h3>
              <p class="text-xs text-text-secondary">Identifies prompt injection risks, jailbreak vulnerabilities, PII exposure, and unsafe output boundaries.</p>
            </div>
            <div class="border border-border bg-surface-secondary/40 rounded-lg p-4">
              <RefreshCw class="w-5 h-5 text-primary mb-2" />
              <h3 class="text-sm font-semibold text-text-primary mb-1">Context Check</h3>
              <p class="text-xs text-text-secondary">Verifies context grounding, reference usage, and whether the prompt provides sufficient background for accurate responses.</p>
            </div>
            <div class="border border-border bg-surface-secondary/40 rounded-lg p-4">
              <GitBranch class="w-5 h-5 text-primary mb-2" />
              <h3 class="text-sm font-semibold text-text-primary mb-1">Formatting Review</h3>
              <p class="text-xs text-text-secondary">Assesses delimiter usage, variable templates, output schema specification, and structural consistency.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Supported Providers -->
      <section class="border-t border-border-subtle pt-10">
        <div class="max-w-[720px]">
          <h2 class="text-xl font-semibold tracking-tight text-text-primary mb-4">Supported LLM Providers</h2>
          <p class="text-sm text-text-secondary leading-relaxed mb-4">
            The AI Auditor works with your own API key from any of these providers. Your key stays in your browser and is never sent to our servers.
          </p>
          <div class="border border-border bg-surface-secondary/40 rounded-lg p-4 text-sm">
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              <li class="flex items-center gap-2 text-text-secondary"><span class="w-1.5 h-1.5 rounded-full bg-primary shrink-0" />OpenAI (GPT-4, GPT-4o, GPT-4o-mini)</li>
              <li class="flex items-center gap-2 text-text-secondary"><span class="w-1.5 h-1.5 rounded-full bg-primary shrink-0" />Anthropic (Claude 3.5 Sonnet, Claude 3 Opus)</li>
              <li class="flex items-center gap-2 text-text-secondary"><span class="w-1.5 h-1.5 rounded-full bg-primary shrink-0" />Google (Gemini 2.0 Flash, Gemini 2.0 Pro)</li>
              <li class="flex items-center gap-2 text-text-secondary"><span class="w-1.5 h-1.5 rounded-full bg-primary shrink-0" />Groq (Llama 3, Mixtral, Gemma — free)</li>
              <li class="flex items-center gap-2 text-text-secondary"><span class="w-1.5 h-1.5 rounded-full bg-primary shrink-0" />Perplexity (Sonar, Sonar Pro)</li>
              <li class="flex items-center gap-2 text-text-secondary"><span class="w-1.5 h-1.5 rounded-full bg-primary shrink-0" />OpenRouter (200+ models)</li>
              <li class="flex items-center gap-2 text-text-secondary"><span class="w-1.5 h-1.5 rounded-full bg-primary shrink-0" />HuggingFace (open‑source models)</li>
              <li class="flex items-center gap-2 text-text-secondary"><span class="w-1.5 h-1.5 rounded-full bg-primary shrink-0" />Custom OpenAI-compatible endpoint</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Use Cases -->
      <section class="border-t border-border-subtle pt-10 pb-4">
        <div class="max-w-[720px]">
          <h2 class="text-xl font-semibold tracking-tight text-text-primary mb-4">When to Use the AI Auditor</h2>
          <div class="flex flex-col gap-4 text-sm">
            <div class="border-l-2 border-primary pl-4">
              <strong class="text-text-primary">Before production deployment</strong>
              <p class="text-xs text-text-secondary mt-0.5">Audit prompts before merging to catch edge cases that deterministic rules miss. The LLM can identify subtle ambiguity and contextual gaps.</p>
            </div>
            <div class="border-l-2 border-primary pl-4">
              <strong class="text-text-primary">When iterating on complex prompts</strong>
              <p class="text-xs text-text-secondary mt-0.5">Multi-step prompts with chained instructions benefit from LLM-level analysis. The auditor provides rewrite suggestions you can apply directly.</p>
            </div>
            <div class="border-l-2 border-primary pl-4">
              <strong class="text-text-primary">After rule-based checks pass</strong>
              <p class="text-xs text-text-secondary mt-0.5">Use the deterministic Prompt Checker as your first pass, then run the AI Auditor for deeper semantic analysis. The two tools complement each other.</p>
            </div>
            <div class="border-l-2 border-primary pl-4">
              <strong class="text-text-primary">Training new prompt engineers</strong>
              <p class="text-xs text-text-secondary mt-0.5">The auditor's detailed findings serve as teaching feedback, helping team members understand what makes a high-quality prompt.</p>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</MarketingLayout>

<script type="application/ld+json" is:inline set:html={JSON.stringify(auditSchema)}></script>
