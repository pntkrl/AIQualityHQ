---
// src/pages/admin.astro
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import AdminConsole from '../components/dashboard/AdminConsole';

const pageTitle = "Owner Admin Dashboard";
const pageDescription = "Administrative console for monitoring website registrations and API usage statistics.";
---

<MarketingLayout title={pageTitle} description={pageDescription} noindex={true}>
  <Header />
  <main class="flex-grow py-12 px-6">
    <AdminConsole client:load />
  </main>
  <Footer />
</MarketingLayout>
