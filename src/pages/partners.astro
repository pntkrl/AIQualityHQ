<MarketingLayout title={pageTitle} description={pageDescription} canonicalUrl={`${siteUrl}/partners`} image={`${siteUrl}/og-checker.png`}>
  <Header />

  <main class="flex-grow py-16 px-6">
    <div class="max-w-[768px] mx-auto flex flex-col gap-12">

      <!-- Hero -->
      <div class="text-center">
        <div class="inline-flex items-center gap-1.5 text-primary text-xs font-mono uppercase tracking-wider mb-2">
          <Sparkles class="w-4 h-4" />
          <span>Curated Stack</span>
        </div>
        <h1 class="text-3xl font-semibold tracking-tight text-text-primary">Partners & Recommended Tools</h1>
        <p class="text-sm text-text-secondary mt-2 max-w-lg mx-auto leading-relaxed">
          Tools and platforms we use, recommend, and integrate with. Every entry is hand-selected by the AIQualityHQ team for quality, reliability, and developer experience.
        </p>
      </div>

      <!-- Partners by Category -->
      {categories.map(category => (
        <section class="border-t border-border-subtle pt-10">
          <h2 class="text-lg font-semibold tracking-tight text-text-primary mb-1">{category}</h2>
          <p class="text-xs text-text-tertiary mb-5">
            {category === 'LLM Provider' && 'Foundation model providers and API platforms.'}
            {category === 'Framework' && 'Libraries and frameworks for building LLM-powered applications.'}
            {category === 'API Gateway' && 'Unified APIs for accessing multiple model providers.'}
            {category === 'Inference' && 'Optimized inference platforms for open-source models.'}
            {category === 'Observability' && 'Monitoring, logging, and debugging tools for production AI.'}
            {category === 'Experiment Tracking' && 'Platforms for evaluating and comparing prompt performance.'}
            {category === 'AI Video' && 'AI-powered video creation and content generation tools.'}
            {category === 'AI Directory' && 'Curated directories for discovering AI tools and applications.'}
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {partners.filter(p => p.category === category).map(partner => (
              <a
                href={partner.url}
                target="_blank"
                rel="noopener noreferrer"
                title={partner.name}
                class="group border border-border bg-surface-secondary/40 rounded-lg p-5 flex flex-col gap-3 hover:border-primary/30 hover:shadow-subtle transition-fast decoration-none"
              >
                <div class="flex items-center justify-between">
                  <h3 class="text-sm font-semibold text-text-primary group-hover:text-primary transition-fast">
                    {partner.name}
                  </h3>
                  <ExternalLink class="w-3.5 h-3.5 text-text-tertiary group-hover:text-primary transition-fast shrink-0" />
                </div>
                <p class="text-xs text-text-secondary leading-relaxed flex-grow">
                  {partner.description}
                </p>
                <div class="flex flex-wrap gap-1.5 mt-auto">
                  {partner.tags.map(tag => (
                    <span class="text-[9px] font-mono px-1.5 py-0.5 rounded border border-border-subtle bg-canvas text-text-tertiary">
                      {tag}
                    </span>
                  ))}
                </div>
              </a>
            ))}
          </div>
        </section>
      ))}

      <!-- CodeMarket Partner Widget -->
      <section class="border-t border-border-subtle pt-10 flex flex-col items-center justify-center text-center">
        <h2 class="text-lg font-semibold tracking-tight text-text-primary mb-4">CodeMarket Partner Badge</h2>
        <div
          data-codemarket-widget="free-ai-prompt-quality-checker-aiqualityhq"
          data-theme-bg="#ffffff"
          data-theme-text="slate-600"
          data-layout="grid"
          data-show-branding="false"
        ></div>
      </section>

      <!-- How We Choose -->
      <section class="border-t border-border-subtle pt-10">
        <h2 class="text-xl font-semibold tracking-tight text-text-primary mb-4">How We Choose Partners</h2>
        <p class="text-sm text-text-secondary leading-relaxed mb-4">
          We only recommend tools we have personally used or thoroughly evaluated. Our selection criteria:
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div class="border border-border bg-surface-secondary/40 rounded-lg p-4">
            <h3 class="text-xs font-semibold text-text-primary mb-1">Proven Reliability</h3>
            <p class="text-[11px] text-text-secondary">Uptime track record, production-grade APIs, and responsive support teams.</p>
          </div>
          <div class="border border-border bg-surface-secondary/40 rounded-lg p-4">
            <h3 class="text-xs font-semibold text-text-primary mb-1">Developer Experience</h3>
            <p class="text-[11px] text-text-secondary">Clear documentation, sensible defaults, and tools that respect your workflow.</p>
          </div>
          <div class="border border-border bg-surface-secondary/40 rounded-lg p-4">
            <h3 class="text-xs font-semibold text-text-primary mb-1">Complementary to AIQualityHQ</h3>
            <p class="text-[11px] text-text-secondary">Tools that strengthen your AI pipeline alongside prompt quality checks.</p>
          </div>
          <div class="border border-border bg-surface-secondary/40 rounded-lg p-4">
            <h3 class="text-xs font-semibold text-text-primary mb-1">Transparent Pricing</h3>
            <p class="text-[11px] text-text-secondary">Free tiers available, clear cost structure, no hidden fees or lock-in.</p>
          </div>
        </div>
      </section>

      <!-- Disclosure -->
      <section class="border-t border-border-subtle pt-10">
        <h2 class="text-xl font-semibold tracking-tight text-text-primary mb-4">Disclosure</h2>
        <p class="text-sm text-text-secondary leading-relaxed mb-3">
          Some links on this page are referral or affiliate links. When you sign up through these links, AIQualityHQ may receive a commission at no additional cost to you. This helps support the development of our free prompt quality tools.
        </p>
        <p class="text-sm text-text-secondary leading-relaxed">
          Affiliate relationships do not influence our editorial recommendations. Every tool listed here was independently evaluated by the AIQualityHQ team based on the criteria described above. We only recommend tools we have personally used or thoroughly tested.
        </p>
      </section>

      <!-- Social Share -->
      <section class="border-t border-border-subtle pt-10">
        <SocialShare />
      </section>

    </div>
  </main>

  <Footer />
</MarketingLayout>

