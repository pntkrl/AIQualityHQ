---
// src/pages/index.astro
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';
import MockDashboard from '../components/marketing/MockDashboard.astro';
import {
  MessageSquare, Brain, Layers, Shield, Lock, ShieldCheck,
  ArrowRight, Zap, Search,
  FileText, ChevronRight
} from '@lucide/astro';

const siteUrl = "https://aiqualityhq.com";

const pageTitle = "Free AI Prompt Quality Checker";
const pageDescription = "Check and evaluate AI prompts with AI Quality HQ. Analyzes prompt quality across six dimensions — structure, clarity, safety, privacy, and more.";
const ogImage = `${siteUrl}/og-checker.png`;

const homeSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "AIQualityHQ Prompt Quality Checker",
      "description": pageDescription,
      "url": siteUrl,
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Web",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "featureList": "Prompt Structure Analysis, Memory & State Check, Context Grounding, Trust & Accuracy, PII & Privacy, Security & Safety"
    },
    {
      "@type": "WebSite",
      "name": "AIQualityHQ",
      "url": siteUrl,
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": `${siteUrl}/search?q={search_term_string}`
        },
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "Organization",
      "name": "AIQualityHQ",
      "url": siteUrl,
      "logo": `${siteUrl}/aiqualityhq-logo.png`,
      "description": "AI Quality HQ helps engineers measure, improve, and trust every AI interaction with deterministic prompt quality analysis."
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is AI Quality HQ and who is it for?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "AI Quality HQ is a free prompt quality analysis platform designed for AI engineers, prompt engineers, and development teams. It runs a deterministic rule engine in your browser to evaluate prompts across six quality dimensions — structure, memory, context, accuracy, privacy, and security — providing actionable scores and improvement suggestions without sending any data to external servers."
          }
        },
        {
          "@type": "Question",
          "name": "Is my prompt data private and secure?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. The Quality Engine processes all prompts entirely in your browser using client-side JavaScript. No prompt text, analysis results, or personal data is transmitted to our servers or any third party. This architecture makes it safe for use with proprietary prompts in healthcare, finance, legal, and other regulated industries."
          }
        },
        {
          "@type": "Question",
          "name": "How is this different from asking ChatGPT to review my prompt?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Unlike LLM-based reviews, AI Quality HQ uses deterministic rules that produce the same score for the same input every time. There is no model randomness, no API cost, and no risk of your prompt being used as training data. The analysis completes in under 10 milliseconds, runs offline, and integrates into CI/CD pipelines where consistency and speed are critical."
          }
        }
      ]
    }
  ]
};
---

<MarketingLayout title={pageTitle} description={pageDescription} canonicalUrl={siteUrl} image={ogImage}>
  <Header />

  <main class="flex-grow">
    <!-- Hero Section -->
    <section class="py-20 md:py-32 px-6">
      <div class="max-w-[1200px] mx-auto text-center flex flex-col items-center">
        <span class="font-mono text-xs font-semibold uppercase tracking-widest text-primary mb-4 bg-primary-subtle px-3 py-1 rounded-full">
          AI Quality Platform
        </span>

        <h1 class="text-4xl md:text-display-2xl font-semibold tracking-tight text-text-primary max-w-4xl leading-tight">
          Check and improve your AI prompt quality in seconds.
        </h1>

        <p class="mt-6 text-base md:text-body-lg text-text-secondary max-w-2xl leading-relaxed">
          AI Quality HQ evaluates your prompts across six core dimensions — structure, safety, privacy, and more — delivering deterministic scores and actionable optimization suggestions instantly.
        </p>

        <div class="mt-8 flex flex-col sm:flex-row items-center gap-3">
          <Button href="/checker" size="lg" variant="primary">Start Free Prompt Checker</Button>
          <Button href="#how-it-works" size="lg" variant="ghost" class="group flex items-center gap-1">
            See How It Works <ArrowRight class="w-4 h-4 group-hover:translate-x-0.5 transition-fast" />
          </Button>
        </div>

        <div class="mt-16 w-full max-w-[1000px] transition-slow hover:-translate-y-1">
          <MockDashboard />
        </div>
      </div>
    </section>

    <!-- Platform Highlights -->
    <section class="border-y border-border-subtle bg-surface-secondary/40 py-10 px-6">
      <div class="max-w-[1200px] mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
          <div>
            <p class="text-2xl font-bold text-text-primary font-mono">6</p>
            <p class="text-xs text-text-tertiary mt-1">Quality dimensions analyzed</p>
          </div>
          <div>
            <p class="text-2xl font-bold text-text-primary font-mono">&lt;10ms</p>
            <p class="text-xs text-text-tertiary mt-1">Average analysis time</p>
          </div>
          <div>
            <p class="text-2xl font-bold text-text-primary font-mono">100%</p>
            <p class="text-xs text-text-tertiary mt-1">Browser-based privacy</p>
          </div>
          <div>
            <p class="text-2xl font-bold text-text-primary font-mono">Free</p>
            <p class="text-xs text-text-tertiary mt-1">No account required</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Problem Section -->
    <section class="py-24 px-6 bg-canvas">
      <div class="max-w-[1200px] mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div>
            <span class="font-mono text-xs font-semibold uppercase tracking-widest text-primary mb-3 block">The Problem</span>
            <h2 class="text-3xl font-semibold tracking-tight text-text-primary leading-tight">
              Poor prompts cost you time, money, and trust.
            </h2>
            <p class="mt-4 text-text-secondary text-sm md:text-base leading-relaxed">
              Every ambiguous or unsafe prompt risks hallucinated outputs, security vulnerabilities, and inconsistent user experiences. Without quality checks, you ship blind.
            </p>
            <ul class="mt-6 flex flex-col gap-3">
              <li class="flex items-start gap-3 text-sm text-text-secondary">
                <span class="w-1.5 h-1.5 rounded-full bg-critical shrink-0 mt-1.5" />
                <span>Prompt injection attacks that bypass safety filters</span>
              </li>
              <li class="flex items-start gap-3 text-sm text-text-secondary">
                <span class="w-1.5 h-1.5 rounded-full bg-critical shrink-0 mt-1.5" />
                <span>Hallucination risks from missing context grounding</span>
              </li>
              <li class="flex items-start gap-3 text-sm text-text-secondary">
                <span class="w-1.5 h-1.5 rounded-full bg-critical shrink-0 mt-1.5" />
                <span>PII exposure through unguarded prompt variables</span>
              </li>
              <li class="flex items-start gap-3 text-sm text-text-secondary">
                <span class="w-1.5 h-1.5 rounded-full bg-critical shrink-0 mt-1.5" />
                <span>Inconsistent outputs from poorly structured instructions</span>
              </li>
            </ul>
          </div>
          <div class="bg-surface-secondary/30 rounded-2xl border border-border-subtle p-8">
            <div class="flex items-center gap-3 mb-4">
              <Shield class="w-10 h-10 p-2.5 rounded-full bg-critical/10 text-critical shrink-0" />
              <div>
                <p class="text-sm font-semibold text-text-primary">Failed Prompt Check</p>
                <p class="text-[11px] text-text-tertiary">Security vulnerability detected</p>
              </div>
            </div>
            <div class="bg-surface rounded-lg border border-border-subtle p-4 font-mono text-xs leading-relaxed">
              <span class="text-critical">HIGH RISK</span> — Prompt injection vector detected<br />
              <span class="text-text-tertiary">Missing output boundary constraints</span><br />
              <span class="text-warning">CAUTION</span> — No system instruction lock found<br />
              <span class="text-text-tertiary">PII variable exposed without sanitization</span>
            </div>
            <p class="mt-4 text-xs text-text-tertiary">AI Quality HQ flags these issues before they reach production.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Features / Solution -->
    <section id="features" class="py-24 px-6 bg-surface-secondary/10 scroll-mt-16">
      <div class="max-w-[1200px] mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <span class="font-mono text-xs font-semibold uppercase tracking-widest text-primary mb-3 block">The Solution</span>
          <h2 class="text-3xl font-semibold tracking-tight text-text-primary">AI Quality Engine — Deterministic Prompt Analysis</h2>
          <p class="mt-4 text-text-secondary text-sm md:text-base leading-relaxed">
            No paid API calls. No black boxes. Our local engine uses static syntax checking, structure heuristics, and rule-based analysis to evaluate prompt quality in under 10 milliseconds.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <Card class="p-6 flex flex-col gap-4">
            <Zap class="w-10 h-10 p-2.5 rounded bg-primary-subtle text-primary border border-primary-border shrink-0" />
            <h3 class="text-base font-semibold text-text-primary">Instant Quality Scores</h3>
            <p class="text-xs md:text-sm text-text-secondary leading-relaxed">
              Get prompt quality scores in milliseconds with our deterministic engine. No AI API calls needed — pure structural analysis and rule-based heuristics.
            </p>
          </Card>

          <Card class="p-6 flex flex-col gap-4">
            <Search class="w-10 h-10 p-2.5 rounded bg-primary-subtle text-primary border border-primary-border shrink-0" />
            <h3 class="text-base font-semibold text-text-primary">Six-Dimension Analysis</h3>
            <p class="text-xs md:text-sm text-text-secondary leading-relaxed">
              Evaluate prompts across structure, memory, context, trust, privacy, and security. Each dimension includes specific pass/fail rules with detailed diagnostics.
            </p>
          </Card>

          <Card class="p-6 flex flex-col gap-4">
            <FileText class="w-10 h-10 p-2.5 rounded bg-primary-subtle text-primary border border-primary-border shrink-0" />
            <h3 class="text-base font-semibold text-text-primary">Actionable Fix Suggestions</h3>
            <p class="text-xs md:text-sm text-text-secondary leading-relaxed">
              Receive specific optimization recommendations for every issue detected. Apply fixes directly, compare changes with diff view, and export results.
            </p>
          </Card>
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section id="how-it-works" class="py-24 px-6 bg-canvas scroll-mt-16">
      <div class="max-w-[1200px] mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <span class="font-mono text-xs font-semibold uppercase tracking-widest text-primary mb-3 block">How It Works</span>
          <h2 class="text-3xl font-semibold tracking-tight text-text-primary">Check your prompt quality in three simple steps</h2>
          <p class="mt-4 text-text-secondary text-sm md:text-base leading-relaxed">
            No signup required. Start analyzing your AI prompts instantly.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="text-center flex flex-col items-center gap-3">
            <div class="w-14 h-14 rounded-xl bg-primary-subtle text-primary border border-primary-border flex items-center justify-center text-xl font-bold font-mono">
              1
            </div>
            <h3 class="text-base font-semibold text-text-primary">Paste Your Prompt</h3>
            <p class="text-xs text-text-secondary leading-relaxed max-w-[260px]">
              Copy any AI prompt template and paste it into the checker. Examples included to get started.
            </p>
          </div>
          <div class="text-center flex flex-col items-center gap-3">
            <div class="w-14 h-14 rounded-xl bg-primary-subtle text-primary border border-primary-border flex items-center justify-center text-xl font-bold font-mono">
              2
            </div>
            <h3 class="text-base font-semibold text-text-primary">Run Quality Analysis</h3>
            <p class="text-xs text-text-secondary leading-relaxed max-w-[260px]">
              Our deterministic engine scans structure, safety, and semantics. Results appear instantly in under 10ms.
            </p>
          </div>
          <div class="text-center flex flex-col items-center gap-3">
            <div class="w-14 h-14 rounded-xl bg-primary-subtle text-primary border border-primary-border flex items-center justify-center text-xl font-bold font-mono">
              3
            </div>
            <h3 class="text-base font-semibold text-text-primary">Review &amp; Improve</h3>
            <p class="text-xs text-text-secondary leading-relaxed max-w-[260px]">
              View dimension scores, pass/fail rules, and fix suggestions. Apply improvements and export your results.
            </p>
          </div>
        </div>

        <div class="text-center mt-12">
          <Button href="/checker" variant="primary" size="lg">Start Prompt Checker</Button>
        </div>
      </div>
    </section>

    <!-- Quality Dimensions -->
    <section id="dimensions" class="py-24 px-6 border-t border-border-subtle bg-surface-secondary/20 scroll-mt-16">
      <div class="max-w-[1200px] mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <h2 class="text-3xl font-semibold tracking-tight text-text-primary">Six Core Dimensions of AI Prompt Quality</h2>
          <p class="mt-4 text-text-secondary text-sm md:text-base leading-relaxed">
            Every prompt analysis grades structural efficiency across six criteria to isolate vulnerabilities and optimize output quality.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <Card class="p-6 flex flex-col gap-4 bg-surface hover:shadow-subtle hover:border-border-strong transition-default">
            <div class="flex items-center justify-between">
              <MessageSquare class="w-8 h-8 p-2 rounded bg-primary-subtle text-primary shrink-0" />
              <Badge variant="success">Excellent</Badge>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-text-primary">Prompt Structure</h3>
              <p class="text-xs text-text-secondary mt-1.5 leading-relaxed">
                Checks core structure, formatting boundaries, role definitions, task descriptions, and explicit constraints.
              </p>
            </div>
          </Card>

          <Card class="p-6 flex flex-col gap-4 bg-surface hover:shadow-subtle hover:border-border-strong transition-default">
            <div class="flex items-center justify-between">
              <Brain class="w-8 h-8 p-2 rounded bg-primary-subtle text-primary shrink-0" />
              <Badge variant="primary">Good</Badge>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-text-primary">Memory &amp; State</h3>
              <p class="text-xs text-text-secondary mt-1.5 leading-relaxed">
                Evaluates how effectively the prompt uses historical context and manages conversation state.
              </p>
            </div>
          </Card>

          <Card class="p-6 flex flex-col gap-4 bg-surface hover:shadow-subtle hover:border-border-strong transition-default">
            <div class="flex items-center justify-between">
              <Layers class="w-8 h-8 p-2 rounded bg-primary-subtle text-primary shrink-0" />
              <Badge variant="success">Excellent</Badge>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-text-primary">Context Grounding</h3>
              <p class="text-xs text-text-secondary mt-1.5 leading-relaxed">
                Measures document usage, retrieval parameters, citation indexes, and reference grounding constraints.
              </p>
            </div>
          </Card>

          <Card class="p-6 flex flex-col gap-4 bg-surface hover:shadow-subtle hover:border-border-strong transition-default">
            <div class="flex items-center justify-between">
              <Shield class="w-8 h-8 p-2 rounded bg-primary-subtle text-primary shrink-0" />
              <Badge variant="warning">Caution</Badge>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-text-primary">Trust &amp; Accuracy</h3>
              <p class="text-xs text-text-secondary mt-1.5 leading-relaxed">
                Flags potential hallucination risks, accuracy issues, grounding gaps, and consistency drops.
              </p>
            </div>
          </Card>

          <Card class="p-6 flex flex-col gap-4 bg-surface hover:shadow-subtle hover:border-border-strong transition-default">
            <div class="flex items-center justify-between">
              <Lock class="w-8 h-8 p-2 rounded bg-primary-subtle text-primary shrink-0" />
              <Badge variant="success">Excellent</Badge>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-text-primary">PII &amp; Privacy</h3>
              <p class="text-xs text-text-secondary mt-1.5 leading-relaxed">
                Detects PII exposure risks, data isolation issues, and potential information leakage vectors.
              </p>
            </div>
          </Card>

          <Card class="p-6 flex flex-col gap-4 bg-surface hover:shadow-subtle hover:border-border-strong transition-default">
            <div class="flex items-center justify-between">
              <ShieldCheck class="w-8 h-8 p-2 rounded bg-primary-subtle text-primary shrink-0" />
              <Badge variant="success">Excellent</Badge>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-text-primary">Security &amp; Safety</h3>
              <p class="text-xs text-text-secondary mt-1.5 leading-relaxed">
                Scans for prompt injection attacks, jailbreak patterns, system instruction locks, and output boundary violations.
              </p>
            </div>
          </Card>
        </div>
      </div>
    </section>

    <!-- Real Use Cases -->
    <section class="py-24 px-6 border-t border-border-subtle bg-canvas">
      <div class="max-w-[1200px] mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <span class="font-mono text-xs font-semibold uppercase tracking-widest text-primary mb-3 block">Use Cases</span>
          <h2 class="text-3xl font-semibold tracking-tight text-text-primary">How Teams Use AI Quality HQ</h2>
          <p class="mt-4 text-text-secondary text-sm md:text-base leading-relaxed">
            From solo developers to engineering teams, here's how prompt quality checks fit into real workflows.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <Card class="p-6 flex flex-col gap-4 min-h-[200px]">
            <div class="w-10 h-10 rounded bg-primary-subtle text-primary border border-primary-border flex items-center justify-center text-lg font-bold font-mono shrink-0">1</div>
            <h3 class="text-base font-semibold text-text-primary">Pre-Deployment Validation</h3>
            <p class="text-xs md:text-sm text-text-secondary leading-relaxed">
              Run quality checks on every prompt template before pushing to production. Catch prompt injection vulnerabilities, missing role definitions, and structural issues that cause inconsistent AI outputs in customer-facing applications.
            </p>
          </Card>

          <Card class="p-6 flex flex-col gap-4 min-h-[200px]">
            <div class="w-10 h-10 rounded bg-primary-subtle text-primary border border-primary-border flex items-center justify-center text-lg font-bold font-mono shrink-0">2</div>
            <h3 class="text-base font-semibold text-text-primary">CI/CD Pipeline Integration</h3>
            <p class="text-xs md:text-sm text-text-secondary leading-relaxed">
              Add prompt quality gates to your pull request workflow. The deterministic engine runs locally with zero API dependencies, returning pass/fail results in milliseconds — ideal for automated testing pipelines that run thousands of checks daily.
            </p>
          </Card>

          <Card class="p-6 flex flex-col gap-4 min-h-[200px]">
            <div class="w-10 h-10 rounded bg-primary-subtle text-primary border border-primary-border flex items-center justify-center text-lg font-bold font-mono shrink-0">3</div>
            <h3 class="text-base font-semibold text-text-primary">Privacy-Sensitive Workflows</h3>
            <p class="text-xs md:text-sm text-text-secondary leading-relaxed">
              All analysis runs entirely in your browser. No prompt data is transmitted to external servers, making it suitable for healthcare, legal, and financial AI applications where data privacy and regulatory compliance are non-negotiable requirements.
            </p>
          </Card>
        </div>
      </div>
    </section>

    <!-- Hostinger Referral Promo Banner -->
    <section class="py-12 px-6 border-t border-border-subtle bg-canvas">
      <div class="max-w-[1200px] mx-auto">
        <div class="relative overflow-hidden rounded-2xl border border-border bg-surface-secondary/20 p-6 md:p-8 flex flex-col md:flex-row items-center justify-between gap-6 transition-default hover:border-primary-border/60 hover:bg-surface-secondary/30">
          <!-- Glow background effect -->
          <div class="absolute -top-24 -right-24 w-48 h-48 rounded-full bg-primary/10 blur-3xl pointer-events-none" aria-hidden="true"></div>
          
          <div class="flex-grow max-w-2xl text-left relative z-10">
            <span class="inline-flex items-center gap-1 font-mono text-[10px] font-semibold uppercase tracking-widest text-primary mb-2 bg-primary-subtle px-2.5 py-0.5 rounded-full select-none">
              Recommended Hosting
            </span>
            <h3 class="text-lg md:text-xl font-semibold tracking-tight text-text-primary text-pretty">
              How We Launched AIQualityHQ
            </h3>
            <p class="mt-2 text-xs md:text-sm text-text-secondary leading-relaxed">
              We registered our domain on Hostinger. Start your own project using our referral link and get a custom domain for free with any 1-year hosting plan.
            </p>
          </div>
          <div class="shrink-0 w-full md:w-auto relative z-10">
            <Button 
              href="https://www.hostinger.com/in?REFERRALCODE=UDVKRALIALRV" 
              target="_blank" 
              rel="noopener noreferrer" 
              variant="primary" 
              size="md"
              class="w-full md:w-auto text-center"
            >
              Claim Free Domain
            </Button>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section (trimmed — full FAQ at /faq) -->
    <section id="faq" class="py-24 px-6 bg-canvas border-t border-border-subtle scroll-mt-16">
      <div class="max-w-[800px] mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-12">
          <h2 class="text-3xl font-semibold tracking-tight text-text-primary">Common Questions</h2>
          <p class="mt-4 text-text-secondary text-sm md:text-base leading-relaxed">
            Quick answers about AI Quality HQ. Visit our <a href="/faq" class="text-primary hover:text-primary-hover underline">full FAQ page</a> for more.
          </p>
        </div>

        <div class="space-y-4">
          <details class="group bg-surface border border-border-subtle rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between p-5 cursor-pointer text-sm font-semibold text-text-primary list-none [&::-webkit-details-marker]:hidden hover:bg-surface-secondary/20 transition-fast">
              What is AI Quality HQ and who is it for?
              <ChevronRight class="w-4 h-4 text-text-tertiary group-open:rotate-90 transition-fast shrink-0" />
            </summary>
            <div class="px-5 pb-5 text-xs text-text-secondary leading-relaxed border-t border-border-subtle pt-4">
              AI Quality HQ is a free prompt quality analysis platform designed for AI engineers, prompt engineers, and development teams. It runs a deterministic rule engine in your browser to evaluate prompts across six quality dimensions — structure, memory, context, accuracy, privacy, and security — providing actionable scores and improvement suggestions without sending any data to external servers.
            </div>
          </details>

          <details class="group bg-surface border border-border-subtle rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between p-5 cursor-pointer text-sm font-semibold text-text-primary list-none [&::-webkit-details-marker]:hidden hover:bg-surface-secondary/20 transition-fast">
              Is my prompt data private and secure?
              <ChevronRight class="w-4 h-4 text-text-tertiary group-open:rotate-90 transition-fast shrink-0" />
            </summary>
            <div class="px-5 pb-5 text-xs text-text-secondary leading-relaxed border-t border-border-subtle pt-4">
              Yes. The Quality Engine processes all prompts entirely in your browser using client-side JavaScript. No prompt text, analysis results, or personal data is transmitted to our servers or any third party. This architecture makes it safe for use with proprietary prompts in healthcare, finance, legal, and other regulated industries.
            </div>
          </details>

          <details class="group bg-surface border border-border-subtle rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between p-5 cursor-pointer text-sm font-semibold text-text-primary list-none [&::-webkit-details-marker]:hidden hover:bg-surface-secondary/20 transition-fast">
              How is this different from asking ChatGPT to review my prompt?
