---
// src/pages/index.astro
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';
import MockDashboard from '../components/marketing/MockDashboard.astro';
import { 
  MessageSquare, 
  Brain, 
  Layers, 
  Shield, 
  Lock, 
  ShieldCheck, 
  Sparkles, 
  CheckCircle, 
  TrendingUp, 
  ArrowRight 
} from '@lucide/astro';

const pageTitle = "The AI Quality Platform";
const pageDescription = "Measure, improve, and trust every AI interaction. AIQualityHQ scores your prompts and responses across six quality dimensions with a local deterministic engine.";
---

<MarketingLayout title={pageTitle} description={pageDescription}>
  <!-- Sticky Header -->
  <Header />

  <main class="flex-grow">
    <!-- Hero Section -->
    <section class="py-20 md:py-32 px-6">
      <div class="max-w-[1200px] mx-auto text-center flex flex-col items-center">
        <!-- Eyebrow -->
        <span class="font-mono text-xs font-semibold uppercase tracking-widest text-primary mb-4 bg-primary-subtle px-3 py-1 rounded-full">
          The AI Quality Platform
        </span>
        
        <!-- Headline -->
        <h1 class="text-4xl md:text-display-2xl font-semibold tracking-tight text-text-primary max-w-4xl leading-tight">
          Measure, improve, and trust <br class="hidden md:inline"/> every AI interaction.
        </h1>
        
        <!-- Subheadline -->
        <p class="mt-6 text-base md:text-body-lg text-text-secondary max-w-2xl leading-relaxed">
          AIQualityHQ evaluates prompts across six core dimensions — supplying deterministic scores, structural diagnoses, and optimization recommendations.
        </p>
        
        <!-- CTAs -->
        <div class="mt-8 flex flex-col sm:flex-row items-center gap-3">
          <Button href="/checker" size="lg" variant="primary">Start Prompt Checker</Button>
          <Button href="#dimensions" size="lg" variant="ghost" class="group flex items-center gap-1">
            Explore Dimensions <ArrowRight class="w-4 h-4 group-hover:translate-x-0.5 transition-fast" />
          </Button>
        </div>

        <!-- CSS Mock Dashboard Visual -->
        <div class="mt-16 w-full max-w-[1000px] transition-slow hover:-translate-y-1">
          <MockDashboard />
        </div>
      </div>
    </section>

    <!-- Trusted By Logos -->
    <section class="border-y border-border-subtle bg-surface-secondary/40 py-10 px-6">
      <div class="max-w-[1200px] mx-auto text-center">
        <h3 class="text-xs font-mono uppercase tracking-widest text-text-tertiary mb-6">Trusted by engineers at</h3>
        <div class="flex flex-wrap items-center justify-center gap-x-12 gap-y-6 opacity-60 grayscale">
          <span class="font-sans font-bold text-base text-text-secondary tracking-tight select-none">ACME CORP</span>
          <span class="font-sans font-bold text-base text-text-secondary tracking-tight select-none">GLOBEX</span>
          <span class="font-sans font-bold text-base text-text-secondary tracking-tight select-none">INITECH</span>
          <span class="font-sans font-bold text-base text-text-secondary tracking-tight select-none">UMBRELLA</span>
          <span class="font-sans font-bold text-base text-text-secondary tracking-tight select-none">HOOLI</span>
        </div>
      </div>
    </section>

    <!-- Feature Grid Section -->
    <section id="features" class="py-24 px-6 scroll-mt-16">
      <div class="max-w-[1200px] mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <h2 class="text-3xl font-semibold tracking-tight text-text-primary">Our Moat: The Quality Engine</h2>
          <p class="mt-4 text-text-secondary text-sm md:text-base leading-relaxed">
            We are not building another wrapper. We run deterministic algorithms to grade syntax, readability, context utilization, and injection safety locally.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Feature 1 -->
          <Card class="p-6 flex flex-col gap-4">
            <div class="w-10 h-10 rounded bg-primary-subtle text-primary border border-primary-border flex items-center justify-center shrink-0">
              <CheckCircle class="w-5 h-5" />
            </div>
            <h3 class="text-base font-semibold text-text-primary">Deterministic Evaluation</h3>
            <p class="text-xs md:text-sm text-text-secondary leading-relaxed">
              No paid AI API calls for grading. We use static syntax checking, length parsing, and structure heuristics to analyze prompts instantly under 10ms.
            </p>
          </Card>

          <!-- Feature 2 -->
          <Card class="p-6 flex flex-col gap-4">
            <div class="w-10 h-10 rounded bg-primary-subtle text-primary border border-primary-border flex items-center justify-center shrink-0">
              <Sparkles class="w-5 h-5" />
            </div>
            <h3 class="text-base font-semibold text-text-primary">Clear Diagnostics</h3>
            <p class="text-xs md:text-sm text-text-secondary leading-relaxed">
              Find exactly what is missing: persona constraints, output boundaries, or input variables. Get actionable suggestions to rebuild prompt structure.
            </p>
          </Card>

          <!-- Feature 3 -->
          <Card class="p-6 flex flex-col gap-4">
            <div class="w-10 h-10 rounded bg-primary-subtle text-primary border border-primary-border flex items-center justify-center shrink-0">
              <TrendingUp class="w-5 h-5" />
            </div>
            <h3 class="text-base font-semibold text-text-primary">Measurable Consistency</h3>
            <p class="text-xs md:text-sm text-text-secondary leading-relaxed">
              Establish a standard baseline for your application instructions. Guard against latency shifts, ambiguity, and prompt regression failures.
            </p>
          </Card>
        </div>
      </div>
    </section>

    <!-- Quality Dimensions Deep-dive -->
    <section id="dimensions" class="py-24 px-6 border-t border-border-subtle bg-surface-secondary/20 scroll-mt-16">
      <div class="max-w-[1200px] mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <h2 class="text-3xl font-semibold tracking-tight text-text-primary">Six Core Dimensions of Quality</h2>
          <p class="mt-4 text-text-secondary text-sm md:text-base leading-relaxed">
            Every analysis grades prompt structural efficiency across 6 core criteria to isolate structural vulnerabilities.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <!-- Card 1: Prompt Structure -->
          <Card class="p-6 flex flex-col gap-4 bg-surface hover:shadow-subtle hover:border-border-strong transition-default">
            <div class="flex items-center justify-between">
              <div class="w-8 h-8 rounded bg-primary-subtle text-primary flex items-center justify-center shrink-0">
                <MessageSquare class="w-4 h-4" />
              </div>
              <Badge variant="success">Excellent</Badge>
            </div>
            <div>
              <h4 class="text-sm font-semibold text-text-primary">Prompt Score</h4>
              <p class="text-xs text-text-secondary mt-1.5 leading-relaxed">
                Checks core structure, formatting boundaries, role definitions, task descriptions, and explicit constraints.
              </p>
            </div>
          </Card>

          <!-- Card 2: Memory Score -->
          <Card class="p-6 flex flex-col gap-4 bg-surface hover:shadow-subtle hover:border-border-strong transition-default">
            <div class="flex items-center justify-between">
              <div class="w-8 h-8 rounded bg-primary-subtle text-primary flex items-center justify-center shrink-0">
                <Brain class="w-4 h-4" />
              </div>
              <Badge variant="primary">Good</Badge>
            </div>
            <div>
              <h4 class="text-sm font-semibold text-text-primary">Memory Score</h4>
              <p class="text-xs text-text-secondary mt-1.5 leading-relaxed">
                Evaluates how effectively the model uses historical context variables and remembers prior user turns.
              </p>
            </div>
          </Card>

          <!-- Card 3: Context Score -->
          <Card class="p-6 flex flex-col gap-4 bg-surface hover:shadow-subtle hover:border-border-strong transition-default">
            <div class="flex items-center justify-between">
              <div class="w-8 h-8 rounded bg-primary-subtle text-primary flex items-center justify-center shrink-0">
                <Layers class="w-4 h-4" />
              </div>
              <Badge variant="success">Excellent</Badge>
            </div>
            <div>
              <h4 class="text-sm font-semibold text-text-primary">Context Score</h4>
              <p class="text-xs text-text-secondary mt-1.5 leading-relaxed">
                Measures document usage, retrieval matching parameters, citation indexes, and reference grounding constraints.
              </p>
            </div>
          </Card>

          <!-- Card 4: Trust Score -->
          <Card class="p-6 flex flex-col gap-4 bg-surface hover:shadow-subtle hover:border-border-strong transition-default">
            <div class="flex items-center justify-between">
              <div class="w-8 h-8 rounded bg-primary-subtle text-primary flex items-center justify-center shrink-0">
                <Shield class="w-4 h-4" />
              </div>
              <Badge variant="warning">Caution</Badge>
            </div>
            <div>
              <h4 class="text-sm font-semibold text-text-primary">Trust Score</h4>
              <p class="text-xs text-text-secondary mt-1.5 leading-relaxed">
                Flags potential hallucination risks, accuracy issues, groundings gaps, and consistency drops.
              </p>
            </div>
          </Card>

          <!-- Card 5: Privacy Score -->
          <Card class="p-6 flex flex-col gap-4 bg-surface hover:shadow-subtle hover:border-border-strong transition-default">
            <div class="flex items-center justify-between">
              <div class="w-8 h-8 rounded bg-primary-subtle text-primary flex items-center justify-center shrink-0">
                <Lock class="w-4 h-4" />
              </div>
              <Badge variant="success">Excellent</Badge>
            </div>
            <div>
              <h4 class="text-sm font-semibold text-text-primary">Privacy Score</h4>
              <p class="text-xs text-text-secondary mt-1.5 leading-relaxed">
                Checks for PII (personally identifiable information) exposure, data isolation risks, and leakages.
              </p>
            </div>
          </Card>

          <!-- Card 6: Security Score -->
          <Card class="p-6 flex flex-col gap-4 bg-surface hover:shadow-subtle hover:border-border-strong transition-default">
            <div class="flex items-center justify-between">
              <div class="w-8 h-8 rounded bg-primary-subtle text-primary flex items-center justify-center shrink-0">
                <ShieldCheck class="w-4 h-4" />
              </div>
              <Badge variant="success">Excellent</Badge>
            </div>
            <div>
              <h4 class="text-sm font-semibold text-text-primary">Security Score</h4>
              <p class="text-xs text-text-secondary mt-1.5 leading-relaxed">
                Scans for prompt injection attacks, jailbreak safety filters, system instruction locks, and output bounds.
              </p>
            </div>
          </Card>
        </div>
      </div>
    </section>

    <!-- Social Proof Testimonials -->
    <section class="py-24 px-6 border-t border-border-subtle bg-canvas">
      <div class="max-w-[1200px] mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <h2 class="text-3xl font-semibold tracking-tight text-text-primary">Trusted by Systems Engineers</h2>
          <p class="mt-4 text-text-secondary text-sm md:text-base leading-relaxed">
            See how prompt designers use AIQualityHQ to measure their model instructions before merging to main.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Testimonial 1 -->
          <Card class="p-6 flex flex-col justify-between min-h-[180px]">
            <p class="text-xs md:text-sm text-text-secondary italic leading-relaxed">
              "We always check our prompts with AIQualityHQ before using them. It completely eliminated regressions in our production customer support chatbot."
            </p>
            <div class="flex items-center gap-2 mt-4 pt-4 border-t border-border-subtle">
              <div class="w-8 h-8 rounded-full bg-surface-tertiary flex items-center justify-center text-xs font-semibold text-text-primary shrink-0">
                SR
              </div>
              <div class="flex flex-col text-[11px]">
                <span class="font-semibold text-text-primary">Sarah R.</span>
                <span class="text-text-tertiary">Senior Staff Engineer, FinTech Inc</span>
              </div>
            </div>
          </Card>

          <!-- Testimonial 2 -->
          <Card class="p-6 flex flex-col justify-between min-h-[180px]">
            <p class="text-xs md:text-sm text-text-secondary italic leading-relaxed">
              "The local deterministic rule engine is a game changer. We run 100,000 prompt checks in our CI pipeline daily for close to zero dollars."
            </p>
            <div class="flex items-center gap-2 mt-4 pt-4 border-t border-border-subtle">
              <div class="w-8 h-8 rounded-full bg-surface-tertiary flex items-center justify-center text-xs font-semibold text-text-primary shrink-0">
                MK
              </div>
              <div class="flex flex-col text-[11px]">
                <span class="font-semibold text-text-primary">Marcus K.</span>
                <span class="text-text-tertiary">VP of Engineering, Cognition Corp</span>
              </div>
            </div>
          </Card>

          <!-- Testimonial 3 -->
          <Card class="p-6 flex flex-col justify-between min-h-[180px]">
            <p class="text-xs md:text-sm text-text-secondary italic leading-relaxed">
              "AIQualityHQ's six-dimension scores helped us debug context leakage in our semantic search apps in minutes instead of manual testing."
            </p>
            <div class="flex items-center gap-2 mt-4 pt-4 border-t border-border-subtle">
              <div class="w-8 h-8 rounded-full bg-surface-tertiary flex items-center justify-center text-xs font-semibold text-text-primary shrink-0">
                TL
              </div>
              <div class="flex flex-col text-[11px]">
                <span class="font-semibold text-text-primary">Tanya L.</span>
                <span class="text-text-tertiary">AI Lead Engineer, Scale.io</span>
              </div>
            </div>
          </Card>
        </div>
      </div>
    </section>

    <!-- Pricing Section -->
    <section id="pricing" class="py-24 px-6 border-t border-border-subtle bg-surface-secondary/10 scroll-mt-16">
      <div class="max-w-[1200px] mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <h2 class="text-3xl font-semibold tracking-tight text-text-primary">Simple, transparent pricing</h2>
          <p class="mt-4 text-text-secondary text-sm md:text-base leading-relaxed">
            Start checking prompts for free. Upgrade for advanced optimizations and benchmarking.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch">
          <!-- Free Tier -->
          <Card class="p-8 flex flex-col justify-between">
            <div>
              <h3 class="text-base font-semibold text-text-primary">Free Tier</h3>
              <p class="text-xs text-text-secondary mt-1.5 min-h-[32px]">Rigorous deterministic evaluation rules.</p>
              <div class="mt-4 flex items-baseline font-mono text-text-primary">
                <span class="text-3xl font-semibold tracking-tight">$0</span>
                <span class="text-xs text-text-tertiary ml-1">/ forever</span>
              </div>
              <ul class="mt-6 flex flex-col gap-3 text-xs text-text-secondary border-t border-border-subtle pt-6">
                <li class="flex items-center gap-2">
                  <CheckCircle class="w-3.5 h-3.5 text-success shrink-0" />
                  <span>Deterministic Rule Engine</span>
                </li>
                <li class="flex items-center gap-2">
                  <CheckCircle class="w-3.5 h-3.5 text-success shrink-0" />
                  <span>6-Dimension Quality Scoring</span>
                </li>
                <li class="flex items-center gap-2">
                  <CheckCircle class="w-3.5 h-3.5 text-success shrink-0" />
                  <span>Structural recommendations</span>
                </li>
              </ul>
            </div>
            <Button href="/checker" class="w-full mt-8" variant="secondary">Start Free</Button>
          </Card>

          <!-- Premium Pro -->
          <Card class="p-8 border-2 border-primary flex flex-col justify-between relative">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-primary text-text-on-primary text-[10px] font-mono tracking-widest uppercase px-3 py-1 rounded-full font-semibold">
              Most Popular
            </div>
            <div>
              <h3 class="text-base font-semibold text-text-primary">Premium Pro</h3>
              <p class="text-xs text-text-secondary mt-1.5 min-h-[32px]">AI-powered optimizations and rewrites.</p>
              <div class="mt-4 flex items-baseline font-mono text-text-primary">
                <span class="text-3xl font-semibold tracking-tight">$29</span>
                <span class="text-xs text-text-tertiary ml-1">/ month</span>
              </div>
              <ul class="mt-6 flex flex-col gap-3 text-xs text-text-secondary border-t border-border-subtle pt-6">
                <li class="flex items-center gap-2">
                  <CheckCircle class="w-3.5 h-3.5 text-success shrink-0" />
                  <span class="font-medium text-text-primary">Everything in Free</span>
                </li>
                <li class="flex items-center gap-2">
                  <CheckCircle class="w-3.5 h-3.5 text-success shrink-0" />
                  <span>AI-powered rewrite engine</span>
                </li>
                <li class="flex items-center gap-2">
                  <CheckCircle class="w-3.5 h-3.5 text-success shrink-0" />
                  <span>Hallucination risk optimization</span>
                </li>
                <li class="flex items-center gap-2">
                  <CheckCircle class="w-3.5 h-3.5 text-success shrink-0" />
                  <span>Cross-model benchmarking</span>
                </li>
              </ul>
            </div>
            <Button href="/checker" class="w-full mt-8" variant="primary">Start Pro Trial</Button>
          </Card>

          <!-- Enterprise -->
          <Card class="p-8 flex flex-col justify-between">
            <div>
              <h3 class="text-base font-semibold text-text-primary">Enterprise</h3>
              <p class="text-xs text-text-secondary mt-1.5 min-h-[32px]">Advanced security checks and team monitoring.</p>
              <div class="mt-4 flex items-baseline font-mono text-text-primary">
                <span class="text-3xl font-semibold tracking-tight">Custom</span>
              </div>
              <ul class="mt-6 flex flex-col gap-3 text-xs text-text-secondary border-t border-border-subtle pt-6">
                <li class="flex items-center gap-2">
                  <CheckCircle class="w-3.5 h-3.5 text-success shrink-0" />
                  <span class="font-medium text-text-primary">Everything in Pro</span>
                </li>
                <li class="flex items-center gap-2">
                  <CheckCircle class="w-3.5 h-3.5 text-success shrink-0" />
                  <span>Custom scoring rubrics</span>
                </li>
                <li class="flex items-center gap-2">
                  <CheckCircle class="w-3.5 h-3.5 text-success shrink-0" />
                  <span>Jailbreak/injection scanners</span>
                </li>
                <li class="flex items-center gap-2">
                  <CheckCircle class="w-3.5 h-3.5 text-success shrink-0" />
                  <span>SSO, SLA, and Team Analytics</span>
                </li>
              </ul>
            </div>
            <Button href="/contact" class="w-full mt-8" variant="secondary">Contact Sales</Button>
          </Card>
        </div>
      </div>
    </section>

    <!-- CTA Band Section -->
    <section class="py-20 md:py-28 px-6 bg-canvas border-t border-border-subtle text-center">
      <div class="max-w-[600px] mx-auto flex flex-col items-center gap-6">
        <h2 class="text-2xl md:text-3xl font-semibold tracking-tight text-text-primary">Ready to verify prompt quality?</h2>
        <p class="text-text-secondary text-sm md:text-base leading-relaxed">
          Paste your prompt template into our Quality Checker to immediately verify syntactic strengths, readability scores, and structural constraints.
        </p>
        <div class="flex items-center gap-3">
          <Button href="/checker" variant="primary" size="lg">Run Prompt Checker</Button>
        </div>
      </div>
    </section>
  </main>

  <!-- Global Footer -->
  <Footer />
</MarketingLayout>
