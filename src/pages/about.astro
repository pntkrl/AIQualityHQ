---
// src/pages/about.astro
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Button from '../components/ui/Button.astro';
import { ShieldCheck, Lock, Zap, Globe, Building2, ArrowRight } from '@lucide/astro';

const siteUrl = "https://aiqualityhq.com";
const pageTitle = "About AIQualityHQ — Prompt Quality Engine for Engineering Teams";
const pageDescription = "AIQualityHQ helps engineering teams build better AI prompts with deterministic quality checks, AI-powered auditing, and CI/CD integration. Learn about our mission and team.";
const canonicalUrl = `${siteUrl}/about`;

const aboutSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${siteUrl}/#organization`,
  "url": siteUrl,
  "name": "AIQualityHQ",
  "description": "Prompt quality evaluation platform for engineering teams.",
  "foundingDate": "2025",
  "email": "support@aiqualityhq.com",
};
---

<MarketingLayout title={pageTitle} description={pageDescription} canonicalUrl={canonicalUrl} image={`${siteUrl}/og-checker.png`}>
  <Header />

  <main class="flex-grow py-16 px-6">
    <div class="max-w-[768px] mx-auto flex flex-col gap-12">

      <!-- Hero -->
      <div class="text-center">
        <Building2 class="w-8 h-8 text-primary mx-auto mb-3" />
        <h1 class="text-3xl font-semibold tracking-tight text-text-primary">About AIQualityHQ</h1>
        <p class="text-sm text-text-secondary mt-2 max-w-lg mx-auto leading-relaxed">
          We help engineering teams ship better AI prompts. Our deterministic Quality Engine gives you measurable, repeatable quality baselines for every prompt in your pipeline.
        </p>
      </div>

      <!-- Mission -->
      <section>
        <h2 class="text-xl font-semibold tracking-tight text-text-primary mb-4">Our Mission</h2>
        <p class="text-sm text-text-secondary leading-relaxed mb-3">
          Prompt engineering is still treated as an art. We believe it should be measurable. AIQualityHQ was built to give teams the same rigor for prompts that they already have for code: static analysis, automated testing, and CI/CD gating.
        </p>
        <p class="text-sm text-text-secondary leading-relaxed">
          Our deterministic engine runs in the browser with zero server-side dependencies. Prompts never leave your machine during analysis, making it suitable for privacy-sensitive workflows in healthcare, finance, and legal AI applications.
        </p>
      </section>

      <!-- Why We Built It -->
      <section class="border-t border-border-subtle pt-10">
        <h2 class="text-xl font-semibold tracking-tight text-text-primary mb-4">Why We Built It</h2>
        <p class="text-sm text-text-secondary leading-relaxed mb-4">
          We saw engineering teams shipping prompts to production without any quality gating. The result was predictable: hallucination-prone responses, prompt injection vulnerabilities, PII leaks, and inconsistent user experiences. Traditional testing approaches didn't apply because prompts are neither code nor natural language alone.
        </p>
        <p class="text-sm text-text-secondary leading-relaxed">
          AIQualityHQ bridges that gap. We provide a structured evaluation framework that catches structural issues, security vulnerabilities, and quality regressions before they reach your users.
        </p>
      </section>

      <!-- Core Values -->
      <section class="border-t border-border-subtle pt-10">
        <h2 class="text-xl font-semibold tracking-tight text-text-primary mb-6">Our Approach</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="border border-border bg-surface-secondary/40 rounded-lg p-5">
            <Lock class="w-5 h-5 text-primary mb-2" />
            <h3 class="text-sm font-semibold text-text-primary">Privacy First</h3>
            <p class="text-xs text-text-secondary mt-1">All analysis happens in your browser. No prompt data is sent to external servers. Your intellectual property stays yours.</p>
          </div>
          <div class="border border-border bg-surface-secondary/40 rounded-lg p-5">
            <Zap class="w-5 h-5 text-primary mb-2" />
            <h3 class="text-sm font-semibold text-text-primary">Deterministic by Default</h3>
            <p class="text-xs text-text-secondary mt-1">Our rule engine produces the same result for the same input every time. No flaky tests, no model drift, no ambiguity in your CI pipeline.</p>
          </div>
          <div class="border border-border bg-surface-secondary/40 rounded-lg p-5">
            <ShieldCheck class="w-5 h-5 text-primary mb-2" />
            <h3 class="text-sm font-semibold text-text-primary">Security Conscious</h3>
            <p class="text-xs text-text-secondary mt-1">We detect prompt injection, jailbreak patterns, PII exposure, and system instruction leaks. Security is built into every analysis.</p>
          </div>
          <div class="border border-border bg-surface-secondary/40 rounded-lg p-5">
            <Globe class="w-5 h-5 text-primary mb-2" />
            <h3 class="text-sm font-semibold text-text-primary">CI/CD Ready</h3>
            <p class="text-xs text-text-secondary mt-1">CLI tools, REST API, GitHub Actions, and SDK support mean prompt quality checks fit naturally into your existing development workflow.</p>
          </div>
        </div>
      </section>

      <!-- Team -->
      <section class="border-t border-border-subtle pt-10 pb-6 text-center">
        <h2 class="text-xl font-semibold tracking-tight text-text-primary mb-3">Get in Touch</h2>
        <p class="text-sm text-text-secondary leading-relaxed mb-6 max-w-md mx-auto">
          Have questions about integrating prompt quality checks into your workflow? We'd love to hear from you.
        </p>
        <div class="flex justify-center gap-3">
          <Button href="/contact" variant="primary" size="lg" class="inline-flex items-center gap-2">
            Contact Us <ArrowRight class="w-4 h-4" />
          </Button>
          <Button href="/docs" variant="ghost" size="lg">
            Read the Docs
          </Button>
        </div>
      </section>

    </div>
  </main>

  <Footer />
</MarketingLayout>

<script type="application/ld+json" is:inline set:html={JSON.stringify(aboutSchema)}></script>
