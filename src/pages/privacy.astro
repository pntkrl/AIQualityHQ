---
// src/pages/privacy.astro
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const siteUrl = "https://www.aiqualityhq.com";
const pageTitle = "Privacy Policy — AIQualityHQ Data Protection";
const pageDescription = "Learn how AIQualityHQ protects your prompt data. Our deterministic engine runs locally in your browser — your prompts never leave your machine.";
---

<MarketingLayout title={pageTitle} description={pageDescription} canonicalUrl={`${siteUrl}/privacy`} image={`${siteUrl}/og-checker.png`}>
  <Header />

  <main class="flex-grow py-16 px-6">
    <div class="max-w-[720px] mx-auto">
      <p class="text-xs text-text-tertiary font-mono mb-4">Last updated: July 3, 2026</p>
      <h1 class="text-3xl font-semibold tracking-tight text-text-primary mb-6">
        Privacy Policy
      </h1>
      
      <div class="prose prose-sm text-text-secondary leading-relaxed flex flex-col gap-6 font-sans">

        <p>
          AIQualityHQ ("we," "our," or "us") provides a free AI prompt quality checking and analysis tool. This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you visit our website and use our services.
        </p>
        <p>
          By using AIQualityHQ, you agree to the practices described in this policy. If you do not agree, please discontinue use of our services.
        </p>

        <!-- 1. Information We Collect -->
        <div>
          <h2 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-2">1. Information We Collect</h2>
          
          <h3 class="text-xs font-semibold text-text-primary mt-4 mb-1">1.1 Information You Provide</h3>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Account Information:</strong> When you create an account, we collect your name and email address. This information is stored locally in your browser's localStorage and is not transmitted to our servers under the Free Tier.</li>
            <li><strong>Prompt Content:</strong> The prompts you analyze are processed entirely in your browser. We do not collect, store, or transmit your prompt text to any server during Free Tier usage.</li>
            <li><strong>Communications:</strong> If you contact us via the contact form or email (support@aiqualityhq.com), we collect your name, email address, and message content solely to respond to your inquiry.</li>
          </ul>

          <h3 class="text-xs font-semibold text-text-primary mt-4 mb-1">1.2 Information Collected Automatically</h3>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Usage Data:</strong> We may collect standard web analytics data such as pages visited, browser type, operating system, referring URLs, and timestamps. This data is aggregated and anonymized.</li>
            <li><strong>Device Information:</strong> IP address, browser fingerprint, and device type may be logged automatically for security and analytics purposes.</li>
          </ul>

          <h3 class="text-xs font-semibold text-text-primary mt-4 mb-1">1.3 Local Storage</h3>
          <p>
            The Free Tier of AIQualityHQ uses your browser's localStorage to store:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>Session authentication data (email, login timestamp)</li>
            <li>User account information (name, email, password hash)</li>
            <li>Diagnostic results and analysis history</li>
            <li>UI preferences (theme selection, layout settings)</li>
          </ul>
          <p>
            This data remains on your device and is not transmitted to our servers. Clearing your browser's local storage will remove this data. We recommend you review your browser's documentation for instructions on managing localStorage.
          </p>
        </div>

        <!-- 2. How We Use Your Information -->
        <div>
          <h2 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-2">2. How We Use Your Information</h2>
          <p>We use the information we collect solely for the following purposes:</p>
          <ul class="list-disc pl-5 space-y-1">
            <li>To operate, maintain, and improve our prompt quality analysis service</li>
            <li>To authenticate your account and provide access to dashboard features</li>
            <li>To respond to your inquiries, support requests, and feedback</li>
            <li>To monitor and analyze usage patterns to improve user experience</li>
            <li>To detect, prevent, and address technical issues or security threats</li>
            <li>To comply with legal obligations and enforce our Terms of Service</li>
          </ul>
        </div>

        <!-- 3. Local Processing -->
        <div>
          <h2 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-2">3. Local Processing Architecture</h2>
          <p>
            A core feature of AIQualityHQ is that our deterministic Quality Engine runs entirely within your browser. For Free Tier users:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>Your prompt text is processed locally and never leaves your device</li>
            <li>Analysis scores, diagnostic results, and quality metrics are computed client-side</li>
            <li>No third-party AI APIs or cloud processing services are used during analysis</li>
            <li>No prompt data is used for training, fine-tuning, or improving external AI models</li>
          </ul>
          <p>
            The Service currently operates entirely in your browser. Any future optional features requiring cloud storage will be clearly disclosed and subject to separate consent before activation.
          </p>
        </div>

        <!-- 4. Cookies -->
        <div>
          <h2 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-2">4. Cookies and Tracking Technologies</h2>
          
          <h3 class="text-xs font-semibold text-text-primary mt-4 mb-1">4.1 Functional Cookies</h3>
          <p>
            We use a minimal set of functional cookies strictly necessary for the operation of our website. These cookies remember your theme preference (light or dark mode) and session state. These cookies do not track you across third-party websites.
          </p>

          <h3 class="text-xs font-semibold text-text-primary mt-4 mb-1">4.2 Third-Party Services</h3>
          <p>
            We self-host our web fonts (Inter and JetBrains Mono) locally from our own servers. No third-party network requests are made to Google Fonts or other external font CDNs, preserving your privacy by not exposing your IP address or browser user agent to third parties.
          </p>

          <h3 class="text-xs font-semibold text-text-primary mt-4 mb-1">4.3 No Tracking Scripts</h3>
          <p>
            We do not run third-party advertising scripts, social media pixels, or cross-site tracking technologies. We do not sell your data to advertisers.
          </p>
        </div>

        <!-- 5. Data Sharing and Disclosure -->
        <div>
          <h2 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-2">5. Data Sharing and Disclosure</h2>
          <p>We do not sell, trade, or rent your personal information to third parties. We may share information only in the following limited circumstances:</p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Service Providers:</strong> We may engage trusted third-party service providers (e.g., hosting infrastructure, email delivery) who are contractually bound to protect your data and use it only for the services we request.</li>
            <li><strong>Legal Requirements:</strong> We may disclose information if required to do so by law, court order, or governmental regulation, or if such disclosure is necessary to protect our rights, property, or the safety of our users.</li>
            <li><strong>Business Transfers:</strong> In the event of a merger, acquisition, or sale of assets, your information may be transferred as part of the transaction. You will be notified via email or prominent notice on our website of any such change in ownership.</li>
          </ul>
        </div>

        <!-- 6. Data Security -->
        <div>
          <h2 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-2">6. Data Security</h2>
          <p>
            We implement industry-standard security measures to protect your information:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>All communications with our website are encrypted using TLS/SSL (HTTPS)</li>
            <li>Authentication credentials are stored locally using your browser's built-in security mechanisms</li>
            <li>We follow security best practices in our codebase and dependency management</li>
            <li>Regular security audits are performed on our infrastructure and application code</li>
          </ul>
          <p>
            However, no method of electronic storage or transmission is 100% secure. We cannot guarantee absolute security of your information. You are responsible for maintaining the confidentiality of your credentials and for the security of your own device.
          </p>
        </div>

        <!-- 7. Data Retention -->
        <div>
          <h2 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-2">7. Data Retention</h2>
          <p>
            We retain your information only as long as necessary to provide our services and fulfill the purposes described in this policy:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>Account information stored in localStorage persists until you clear your browser data or delete your account</li>
            <li>Contact form submissions are retained for the duration necessary to address your inquiry and for record-keeping purposes</li>
            <li>Anonymized usage analytics may be retained indefinitely for service improvement</li>
          </ul>
          <p>
            You may delete your account and associated data at any time by clearing your browser's localStorage or by contacting our support team. Note that clearing localStorage is irreversible and will remove all locally stored analysis history.
          </p>
        </div>

        <!-- 8. Your Rights -->
        <div>
          <h2 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-2">8. Your Rights and Choices</h2>
          <p>Depending on your jurisdiction, you may have the following rights regarding your personal information:</p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Access:</strong> Request a copy of the personal information we hold about you</li>
            <li><strong>Correction:</strong> Request correction of inaccurate or incomplete information</li>
            <li><strong>Deletion:</strong> Request deletion of your personal information, subject to certain exceptions</li>
            <li><strong>Portability:</strong> Request transfer of your data in a structured, commonly used format</li>
            <li><strong>Objection:</strong> Object to the processing of your personal information for certain purposes</li>
            <li><strong>Withdrawal of Consent:</strong> Withdraw consent at any time where processing is based on consent</li>
          </ul>
          <p>
            To exercise any of these rights, please contact us at support@aiqualityhq.com. We will respond to your request within 30 days. We may need to verify your identity before processing your request.
          </p>
        </div>

        <!-- 9. Children's Privacy -->
        <div>
          <h2 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-2">9. Children's Privacy</h2>
          <p>
            AIQualityHQ is not directed to individuals under the age of 13 (or the applicable age of consent in your jurisdiction). We do not knowingly collect personal information from children. If we become aware that a child has provided us with personal information, we will take steps to delete such information promptly. If you believe a child has provided us with personal data, please contact us at support@aiqualityhq.com.
          </p>
        </div>

        <!-- 10. International Users -->
        <div>
          <h2 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-2">10. International Users</h2>
          <p>
            AIQualityHQ is operated from the United States. If you access our services from outside the United States, your information may be transferred to, stored, and processed in the United States. By using our services, you consent to the transfer of your information to the United States and the application of U.S. law and regulations.
          </p>
          <p>
            For users in the European Economic Area (EEA), the United Kingdom, or Switzerland, we process your personal data in accordance with the General Data Protection Regulation (GDPR). Our legal basis for processing is typically your consent or our legitimate interest in providing and improving our services.
          </p>
        </div>

        <!-- 11. Changes -->
        <div>
          <h2 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-2">11. Changes to This Privacy Policy</h2>
          <p>
            We may update this Privacy Policy from time to time to reflect changes in our practices, legal obligations, or industry standards. We will notify you of material changes by posting the updated policy on this page with a revised "Last updated" date. For significant changes, we may also provide notice via email or through our website.
          </p>
          <p>
            Your continued use of AIQualityHQ after any changes constitutes your acceptance of the updated policy. We encourage you to review this policy periodically.
          </p>
        </div>

        <!-- 12. Contact -->
        <div>
          <h2 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-2">12. Contact Us</h2>
          <p>
            If you have questions, concerns, or requests regarding this Privacy Policy or our data practices, please contact us:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>Email: support@aiqualityhq.com</li>
            <li>Contact form: <a href="/contact" class="text-primary hover:text-primary-hover underline">aiqualityhq.com/contact</a></li>
          </ul>
        </div>

      </div>
    </div>
  </main>

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebPage",
          "@id": "https://www.aiqualityhq.com/privacy",
          "url": "https://www.aiqualityhq.com/privacy",
          "name": "Privacy Policy — AIQualityHQ Data Protection",
          "description": "Learn how AIQualityHQ protects your prompt data. Deterministic engine runs locally in your browser.",
          "isPartOf": {
            "@id": "https://www.aiqualityhq.com/#website"
          }
        },
        {
          "@type": "Organization",
          "@id": "https://www.aiqualityhq.com/#organization",
          "name": "AIQualityHQ",
          "url": "https://www.aiqualityhq.com",
          "privacyPolicy": "https://www.aiqualityhq.com/privacy"
        }
      ]
    }
  </script>

  <Footer />
</MarketingLayout>
