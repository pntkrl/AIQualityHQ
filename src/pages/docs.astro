---
// src/pages/docs.astro
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { BookOpen, ChevronRight, Code, Terminal, Shield, Lock, Brain, Layers, MessageSquare, FileText, Search } from '@lucide/astro';

const siteUrl = "https://aiqualityhq.com";
const pageTitle = "AIQualityHQ Docs — Prompt Quality Engine Guide";
const pageDescription = "Complete documentation for the AIQualityHQ deterministic Quality Engine. Learn prompt scoring, six-dimension diagnostic rules, and integration guides.";
---

<MarketingLayout title={pageTitle} description={pageDescription} canonicalUrl={`${siteUrl}/docs`} image={`${siteUrl}/og-checker.png`}>
  <Header activeNav="docs" />

  <div class="w-full flex-grow max-w-[1200px] mx-auto px-6 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      <!-- LEFT SIDEBAR -->
      <aside class="hidden lg:block lg:col-span-3 sticky top-24 border-r border-border-subtle pr-4 h-[calc(100vh-120px)] overflow-y-auto">
        <div class="mb-6">
          <span class="text-[10px] font-mono font-semibold uppercase tracking-widest text-text-tertiary block mb-2">On this page</span>
          <ul class="flex flex-col gap-1 text-xs" id="docs-toc">
            <li><a href="#introduction" class="flex items-center gap-1.5 h-8 px-2 rounded-md bg-primary-subtle text-primary font-medium">Introduction</a></li>
            <li><a href="#how-it-works" class="flex items-center gap-1.5 h-8 px-2 rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">How it Works</a></li>
            <li><a href="#quick-start" class="flex items-center gap-1.5 h-8 px-2 rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">Quick Start</a></li>
            <li><a href="#scoring-rubric" class="flex items-center gap-1.5 h-8 px-2 rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">Scoring Rubric</a></li>
            <li><a href="#prompt-structure" class="flex items-center gap-1.5 h-8 px-2 rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">Prompt Structure</a></li>
            <li><a href="#memory-state" class="flex items-center gap-1.5 h-8 px-2 rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">Memory & State</a></li>
            <li><a href="#context-grounding" class="flex items-center gap-1.5 h-8 px-2 rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">Context Grounding</a></li>
            <li><a href="#trust-accuracy" class="flex items-center gap-1.5 h-8 px-2 rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">Trust & Accuracy</a></li>
            <li><a href="#pii-privacy" class="flex items-center gap-1.5 h-8 px-2 rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">PII & Privacy</a></li>
            <li><a href="#security-safety" class="flex items-center gap-1.5 h-8 px-2 rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">Security & Safety</a></li>
            <li><a href="#rest-api" class="flex items-center gap-1.5 h-8 px-2 rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">REST API</a></li>
            <li><a href="#cli-tool" class="flex items-center gap-1.5 h-8 px-2 rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">CLI Tool</a></li>
            <li><a href="#github-actions" class="flex items-center gap-1.5 h-8 px-2 rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">GitHub Actions</a></li>
            <li><a href="#sdk" class="flex items-center gap-1.5 h-8 px-2 rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">SDK Reference</a></li>
            <li><a href="#troubleshooting" class="flex items-center gap-1.5 h-8 px-2 rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">Troubleshooting</a></li>
            <li><a href="#faq" class="flex items-center gap-1.5 h-8 px-2 rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">FAQ</a></li>
          </ul>
        </div>
        <hr class="border-border-subtle mb-6" />
        <nav class="flex flex-col gap-6" aria-label="Documentation navigation">
          <div>
            <span class="text-[10px] font-mono font-semibold uppercase tracking-widest text-text-tertiary block mb-2">Getting Started</span>
            <ul class="flex flex-col gap-1 text-xs">
              <li><a href="#introduction" class="flex items-center gap-1.5 h-8 px-2 rounded-md bg-primary-subtle text-primary font-medium">Introduction</a></li>
              <li><a href="#how-it-works" class="flex items-center gap-1.5 h-8 px-2 rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">How it Works</a></li>
              <li><a href="#quick-start" class="flex items-center gap-1.5 h-8 px-2 rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">Quick Start</a></li>
              <li><a href="#scoring-rubric" class="flex items-center gap-1.5 h-8 px-2 rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">Scoring Rubric</a></li>
            </ul>
          </div>
          <div>
            <span class="text-[10px] font-mono font-semibold uppercase tracking-widest text-text-tertiary block mb-2">Diagnostic Rules</span>
            <ul class="flex flex-col gap-1 text-xs">
              <li><a href="#prompt-structure" class="h-8 px-2 flex items-center rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">Prompt Structure</a></li>
              <li><a href="#memory-state" class="h-8 px-2 flex items-center rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">Memory & State</a></li>
              <li><a href="#context-grounding" class="h-8 px-2 flex items-center rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">Context Grounding</a></li>
              <li><a href="#trust-accuracy" class="h-8 px-2 flex items-center rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">Trust & Accuracy</a></li>
              <li><a href="#pii-privacy" class="h-8 px-2 flex items-center rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">PII & Privacy</a></li>
              <li><a href="#security-safety" class="h-8 px-2 flex items-center rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">Security & Safety</a></li>
            </ul>
          </div>
          <div>
            <span class="text-[10px] font-mono font-semibold uppercase tracking-widest text-text-tertiary block mb-2">Integration</span>
            <ul class="flex flex-col gap-1 text-xs">
              <li><a href="#rest-api" class="h-8 px-2 flex items-center rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">REST API</a></li>
              <li><a href="#cli-tool" class="h-8 px-2 flex items-center rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">CLI Tool</a></li>
              <li><a href="#github-actions" class="h-8 px-2 flex items-center rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">GitHub Actions</a></li>
              <li><a href="#sdk" class="h-8 px-2 flex items-center rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">SDK Reference</a></li>
            </ul>
          </div>
          <div>
            <span class="text-[10px] font-mono font-semibold uppercase tracking-widest text-text-tertiary block mb-2">Support</span>
            <ul class="flex flex-col gap-1 text-xs">
              <li><a href="#troubleshooting" class="h-8 px-2 flex items-center rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">Troubleshooting</a></li>
              <li><a href="#faq" class="h-8 px-2 flex items-center rounded-md text-text-secondary hover:text-text-primary hover:bg-surface-secondary">FAQ</a></li>
            </ul>
          </div>
        </nav>
      </aside>

      <!-- MAIN CONTENT -->
      <main class="lg:col-span-9 max-w-[840px] text-text-secondary leading-relaxed flex flex-col gap-10 font-sans">
        
        <!-- Introduction -->
        <section id="introduction" class="scroll-mt-24">
          <div class="flex items-center gap-2 text-primary font-mono text-[11px] uppercase tracking-wider mb-2">
            <BookOpen class="w-4 h-4" />
            <span>Developer Reference</span>
          </div>
          <h1 class="text-3xl font-semibold tracking-tight text-text-primary mb-4">
            AIQualityHQ Prompt Quality Engine Documentation
          </h1>
          <p class="mb-2">
            AIQualityHQ runs a rule engine in your browser to check AI prompt quality. You get a clear quality score for each prompt instead of guessing if it is good enough.
          </p>
          <p class="mb-2">
            The engine runs in your browser. No prompt data leaves your machine. This makes it safe for private workflows in healthcare, finance, and legal AI apps.
          </p>
          <p>
            This guide covers scoring rules, diagnostic checks, API integration, and common fixes.
          </p>
        </section>

        <!-- How It Works -->
        <section id="how-it-works" class="scroll-mt-24 border-t border-border-subtle pt-10">
          <h2 class="text-xl font-semibold tracking-tight text-text-primary mb-4">How It Works</h2>
          <p class="mb-4">
            The Quality Engine checks prompt text across six areas. Each area has pass/fail rules that look at specific prompt traits. The engine returns scores for each area and an overall rating.
          </p>
          <p class="mb-4">The evaluation pipeline follows three stages:</p>
          <div class="flex flex-col gap-3">
            <div class="flex gap-2">
              <span class="w-5 h-5 rounded bg-primary-subtle text-primary flex items-center justify-center text-[10px] font-bold font-mono shrink-0 mt-0.5">1</span>
              <div>
                <strong class="text-text-primary">Lexical Analysis</strong>
                <p class="text-xs">The engine reads the prompt and looks for key parts: role definitions, instruction blocks, and output format clues.</p>
              </div>
            </div>
            <div class="flex gap-2">
              <span class="w-5 h-5 rounded bg-primary-subtle text-primary flex items-center justify-center text-[10px] font-bold font-mono shrink-0 mt-0.5">2</span>
              <div>
                <strong class="text-text-primary">Rule Evaluation</strong>
                <p class="text-xs">Each dimension runs its set of deterministic rules. For example, the Security dimension checks for prompt injection patterns and jailbreak attempts.</p>
              </div>
            </div>
            <div class="flex gap-2">
              <span class="w-5 h-5 rounded bg-primary-subtle text-primary flex items-center justify-center text-[10px] font-bold font-mono shrink-0 mt-0.5">3</span>
              <div>
                <strong class="text-text-primary">Score Aggregation</strong>
                <p class="text-xs">Dimension scores are weighted and combined into an overall score. A detailed report with pass/fail findings is generated for review.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Quick Start -->
        <section id="quick-start" class="scroll-mt-24 border-t border-border-subtle pt-10">
          <h2 class="text-xl font-semibold tracking-tight text-text-primary mb-4">Quick Start</h2>
          <p class="mb-4">
            You can start checking prompts immediately without signup or API keys. Here are a few example prompts to try:
          </p>
          <div class="border border-border bg-surface-secondary/40 rounded-lg p-4 font-mono text-xs text-text-secondary leading-relaxed mb-4">
            <span class="text-primary font-bold">&gt;</span> You are a helpful assistant. Answer concisely.<br/>
            <span class="text-primary font-bold">&gt;</span> Translate the following to French: Hello world<br/>
            <span class="text-primary font-bold">&gt;</span> System: You are an expert coder. User: Write a function
          </div>
          <p class="mb-2">Steps to run your first analysis:</p>
          <ol class="list-decimal pl-5 flex flex-col gap-2 text-sm">
            <li>Navigate to the <a href="/checker" class="text-primary hover:text-primary-hover underline">Prompt Checker</a> page.</li>
            <li>Paste your prompt template into the input area.</li>
            <li>Click <strong>Analyze</strong> to run the Quality Engine.</li>
            <li>Review the six-dimension score breakdown and individual pass/fail findings.</li>
            <li>Use the fix checklist to address flagged issues.</li>
          </ol>
        </section>

        <!-- Scoring Rubric -->
        <section id="scoring-rubric" class="scroll-mt-24 border-t border-border-subtle pt-10">
          <h2 class="text-xl font-semibold tracking-tight text-text-primary mb-4">Scoring Rubric</h2>
          <p class="mb-4">
            Each area scores from 0 to 100 based on how many rules pass. The overall score uses weighted averages:
          </p>
          <div class="border border-border bg-surface-secondary/40 rounded-lg p-4 font-mono text-xs text-text-secondary leading-relaxed mb-4">
            Overall Score = 0.20 &times; Prompt Structure +<br/>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;0.15 &times; Memory &amp; State +<br/>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;0.20 &times; Context Grounding +<br/>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;0.25 &times; Trust &amp; Accuracy +<br/>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;0.10 &times; PII &amp; Privacy +<br/>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;0.10 &times; Security &amp; Safety
          </div>
          <div class="border border-border bg-surface-secondary/40 rounded-lg p-4 text-xs">
            <p class="mb-2"><strong class="text-text-primary">Score interpretation:</strong></p>
            <ul class="flex flex-col gap-1.5">
              <li><span class="text-green-500 font-bold">90-100</span> &mdash; Excellent: Production-ready prompt</li>
              <li><span class="text-yellow-500 font-bold">70-89</span> &mdash; Good: Minor improvements recommended</li>
              <li><span class="text-orange-500 font-bold">50-69</span> &mdash; Fair: Structural or safety issues need attention</li>
              <li><span class="text-red-500 font-bold">0-49</span> &mdash; Poor: Significant risks detected</li>
            </ul>
          </div>
        </section>

        <!-- Diagnostic Rules: Prompt Structure -->
        <section id="prompt-structure" class="scroll-mt-24 border-t border-border-subtle pt-10">
          <div class="flex items-center gap-2 text-primary mb-3">
            <MessageSquare class="w-5 h-5" />
            <h2 class="text-xl font-semibold tracking-tight text-text-primary">Prompt Structure</h2>
          </div>
          <p class="mb-3">Evaluates whether the prompt follows engineering best practices for formatting, role definition, task clarity, and constraints.</p>
          <div class="flex flex-col gap-2 text-sm">
            <div class="flex gap-2"><ChevronRight class="w-4 h-4 text-primary shrink-0" /><span><strong>Role definition:</strong> Checks if the prompt assigns a clear persona or system role (e.g., "You are an expert...").</span></div>
            <div class="flex gap-2"><ChevronRight class="w-4 h-4 text-primary shrink-0" /><span><strong>Task clarity:</strong> Verifies the presence of imperative verbs (translate, summarize, write, analyze).</span></div>
            <div class="flex gap-2"><ChevronRight class="w-4 h-4 text-primary shrink-0" /><span><strong>Boundary separation:</strong> Checks for delimiters like backticks, XML tags, or markdown separators.</span></div>
            <div class="flex gap-2"><ChevronRight class="w-4 h-4 text-primary shrink-0" /><span><strong>Output format:</strong> Ensures expected output structure is specified (JSON, table, list).</span></div>
          </div>
        </section>

        <!-- Memory & State -->
        <section id="memory-state" class="scroll-mt-24 border-t border-border-subtle pt-10">
          <div class="flex items-center gap-2 text-primary mb-3">
            <Brain class="w-5 h-5" />
            <h2 class="text-xl font-semibold tracking-tight text-text-primary">Memory &amp; State</h2>
          </div>
          <p class="mb-3">Verifies that the prompt properly manages conversation context, history, and session state.</p>
          <div class="flex flex-col gap-2 text-sm">
            <div class="flex gap-2"><ChevronRight class="w-4 h-4 text-primary shrink-0" /><span><strong>Context retention:</strong> Checks if instructions reference prior context or conversation history.</span></div>
            <div class="flex gap-2"><ChevronRight class="w-4 h-4 text-primary shrink-0" /><span><strong>State directives:</strong> Verifies explicit state management instructions (reset, continue, ignore previous).</span></div>
          </div>
        </section>

        <!-- Context Grounding -->
        <section id="context-grounding" class="scroll-mt-24 border-t border-border-subtle pt-10">
          <div class="flex items-center gap-2 text-primary mb-3">
            <Layers class="w-5 h-5" />
            <h2 class="text-xl font-semibold tracking-tight text-text-primary">Context Grounding</h2>
          </div>
          <p class="mb-3">Assesses how well the prompt grounds the model with reference materials, data sources, and domain context.</p>
          <div class="flex flex-col gap-2 text-sm">
            <div class="flex gap-2"><ChevronRight class="w-4 h-4 text-primary shrink-0" /><span><strong>Document references:</strong> Checks for cited sources or embedded reference content.</span></div>
            <div class="flex gap-2"><ChevronRight class="w-4 h-4 text-primary shrink-0" /><span><strong>Parameter grounding:</strong> Verifies variable placeholders are used instead of hardcoded values.</span></div>
          </div>
        </section>

        <!-- Trust & Accuracy -->
        <section id="trust-accuracy" class="scroll-mt-24 border-t border-border-subtle pt-10">
          <div class="flex items-center gap-2 text-primary mb-3">
            <Shield class="w-5 h-5" />
            <h2 class="text-xl font-semibold tracking-tight text-text-primary">Trust &amp; Accuracy</h2>
          </div>
          <p class="mb-3">Flags hallucination risks, factual accuracy issues, and consistency problems in the prompt design.</p>
          <div class="flex flex-col gap-2 text-sm">
            <div class="flex gap-2"><ChevronRight class="w-4 h-4 text-primary shrink-0" /><span><strong>Conflicting instructions:</strong> Detects contradictory directives within the prompt.</span></div>
            <div class="flex gap-2"><ChevronRight class="w-4 h-4 text-primary shrink-0" /><span><strong>Confidence calibration:</strong> Checks for speculative language and uncertainty markers.</span></div>
          </div>
        </section>

        <!-- PII & Privacy -->
        <section id="pii-privacy" class="scroll-mt-24 border-t border-border-subtle pt-10">
          <div class="flex items-center gap-2 text-primary mb-3">
            <Lock class="w-5 h-5" />
            <h2 class="text-xl font-semibold tracking-tight text-text-primary">PII &amp; Privacy</h2>
          </div>
          <p class="mb-3">Detects personally identifiable information exposure risks and data leakage vectors in prompts.</p>
          <div class="flex flex-col gap-2 text-sm">
            <div class="flex gap-2"><ChevronRight class="w-4 h-4 text-primary shrink-0" /><span><strong>Email detection:</strong> Flags email addresses embedded in prompts.</span></div>
            <div class="flex gap-2"><ChevronRight class="w-4 h-4 text-primary shrink-0" /><span><strong>Credential patterns:</strong> Detects API keys, passwords, and token patterns.</span></div>
            <div class="flex gap-2"><ChevronRight class="w-4 h-4 text-primary shrink-0" /><span><strong>Data isolation:</strong> Checks if private data is isolated from shared context.</span></div>
          </div>
        </section>

        <!-- Security & Safety -->
        <section id="security-safety" class="scroll-mt-24 border-t border-border-subtle pt-10">
          <div class="flex items-center gap-2 text-primary mb-3">
            <Shield class="w-5 h-5" />
            <h2 class="text-xl font-semibold tracking-tight text-text-primary">Security &amp; Safety</h2>
          </div>
          <p class="mb-3">Scans for prompt injection, jailbreak attempts, system instruction leaks, and output boundary violations.</p>
          <div class="flex flex-col gap-2 text-sm">
            <div class="flex gap-2"><ChevronRight class="w-4 h-4 text-primary shrink-0" /><span><strong>Injection patterns:</strong> Detects "ignore previous instructions" and role-escalation attacks.</span></div>
            <div class="flex gap-2"><ChevronRight class="w-4 h-4 text-primary shrink-0" /><span><strong>Jailbreak attempts:</strong> Flags known jailbreak prefixes and DAN-style patterns.</span></div>
            <div class="flex gap-2"><ChevronRight class="w-4 h-4 text-primary shrink-0" /><span><strong>Instruction lock:</strong> Verifies system instructions are properly bounded and protected.</span></div>
          </div>
        </section>

        <!-- REST API -->
        <section id="rest-api" class="scroll-mt-24 border-t border-border-subtle pt-10">
          <div class="flex items-center gap-2 text-primary mb-3">
            <Code class="w-5 h-5" />
            <h2 class="text-xl font-semibold tracking-tight text-text-primary">REST API Reference</h2>
          </div>
          <p class="mb-4">
            The AIQualityHQ REST API allows you to programmatically analyze prompts. Authentication is via bearer token.
          </p>
          <div class="border border-border bg-surface-secondary/40 rounded-lg p-4 font-mono text-xs text-text-secondary leading-relaxed mb-4">
            {`POST https://api.aiqualityhq.com/v1/check

Headers:
  Authorization: Bearer <your_api_key>
  Content-Type: application/json

Body:
  {
    "prompt": "Your prompt text here",
    "dimensions": ["structure", "security", "privacy"]
  }`}
          </div>
          <p class="text-xs text-text-tertiary">Generate API keys in your <a href="/settings" class="text-primary hover:text-primary-hover underline">Account Settings</a>.</p>
        </section>

        <!-- CLI Tool -->
        <section id="cli-tool" class="scroll-mt-24 border-t border-border-subtle pt-10">
          <div class="flex items-center gap-2 text-primary mb-3">
            <Terminal class="w-5 h-5" />
            <h2 class="text-xl font-semibold tracking-tight text-text-primary">CLI Tool</h2>
          </div>
          <p class="mb-4">
            Use the AIQualityHQ CLI to check prompts directly from your terminal. Install via npm:
          </p>
          <div class="border border-border bg-surface-secondary/40 rounded-lg p-4 font-mono text-xs text-text-secondary leading-relaxed mb-4">
            {`npm install -g @aiqualityhq/cli

aq check --prompt "Your prompt text"
aq check --file ./prompts/example.txt
aq check --ci --json`}
          </div>
          <p class="text-xs text-text-tertiary">The <code class="font-mono bg-surface-secondary px-1 rounded">--ci</code> flag exits with a non-zero code on failing prompts, suitable for CI/CD pipelines.</p>
        </section>

        <!-- GitHub Actions -->
        <section id="github-actions" class="scroll-mt-24 border-t border-border-subtle pt-10">
          <div class="flex items-center gap-2 text-primary mb-3">
            <FileText class="w-5 h-5" />
            <h2 class="text-xl font-semibold tracking-tight text-text-primary">GitHub Actions</h2>
          </div>
          <p class="mb-4">
            Add prompt quality checks to your pull request workflow. Create <code class="font-mono bg-surface-secondary px-1 rounded">.github/workflows/prompt-check.yml</code>:
          </p>
          <div class="border border-border bg-surface-secondary/40 rounded-lg p-4 font-mono text-xs text-text-secondary leading-relaxed mb-4">
            {`name: Prompt Quality Check
on: [pull_request]
jobs:
  check:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - run: npx @aiqualityhq/cli check --glob "prompts/**/*.md"`}
          </div>
        </section>

        <!-- SDK Reference -->
        <section id="sdk" class="scroll-mt-24 border-t border-border-subtle pt-10">
          <div class="flex items-center gap-2 text-primary mb-3">
            <Search class="w-5 h-5" />
            <h2 class="text-xl font-semibold tracking-tight text-text-primary">SDK Reference</h2>
          </div>
          <p class="mb-4">
            Integrate the Quality Engine directly into your Node.js or TypeScript application:
          </p>
          <div class="border border-border bg-surface-secondary/40 rounded-lg p-4 font-mono text-xs text-text-secondary leading-relaxed mb-4">
            {`import { analyzePrompt } from '@aiqualityhq/engine';

const result = await analyzePrompt({
  text: "Your prompt here",
  dimensions: ['structure', 'security']
});

console.log(result.score);      // 87
console.log(result.findings);   // [{ rule, passed, message }]`}
          </div>
        </section>

        <!-- Troubleshooting -->
        <section id="troubleshooting" class="scroll-mt-24 border-t border-border-subtle pt-10">
          <h2 class="text-xl font-semibold tracking-tight text-text-primary mb-4">Troubleshooting</h2>
          <div class="flex flex-col gap-3">
