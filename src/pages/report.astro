---
// src/pages/report.astro
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import ReportViewer from '../components/dashboard/ReportViewer';
import { BookOpen } from '@lucide/astro';

const siteUrl = "https://aiqualityhq.com";
const pageTitle = "Prompt Quality Report";
const pageDescription = "View detailed prompt quality analysis reports from AIQualityHQ. Review six-dimension scores, diagnostic rules, and optimization recommendations.";
---

<MarketingLayout title={pageTitle} description={pageDescription} canonicalUrl={`${siteUrl}/report`} image={`${siteUrl}/og-checker.png`} noindex={true}>
  <Header activeNav="checker" />

  <main class="flex-grow py-12 px-6">
    <div class="max-w-[1200px] mx-auto flex flex-col gap-8">
      
      <!-- Page Header -->
      <div class="border-b border-border-subtle pb-6 max-w-[800px] mx-auto w-full">
        <div class="flex items-center gap-2 text-primary font-mono text-xs uppercase tracking-wider mb-2">
          <BookOpen class="w-4 h-4" />
          <span>Diagnostic Log Summary</span>
        </div>
        <h1 class="text-3xl font-semibold tracking-tight text-text-primary">
          Verify Quality Report
        </h1>
        <p class="text-sm text-text-secondary mt-1.5 leading-relaxed font-sans">
          This report compiles static syntax assessments, rule checklists, and diagnostic scores compiled by the AIQualityHQ Quality Engine.
        </p>
      </div>

      <!-- Hydrated Report Viewer React Island -->
      <ReportViewer client:load />

    </div>
  </main>

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebPage",
          "@id": "https://aiqualityhq.com/report",
          "url": "https://aiqualityhq.com/report",
          "name": "Prompt Quality Report — AIQualityHQ Analysis",
          "description": "View detailed prompt quality analysis reports from AIQualityHQ with six-dimension scores and diagnostic rules.",
          "isPartOf": {
            "@id": "https://aiqualityhq.com/#website"
          }
        },
        {
          "@type": "WebSite",
          "@id": "https://aiqualityhq.com/#website",
          "url": "https://aiqualityhq.com",
          "name": "AIQualityHQ",
          "description": "Free AI prompt quality checker and analysis tool."
        }
      ]
    }
  </script>

  <Footer />
</MarketingLayout>
