---
// src/layouts/DashboardLayout.astro
import ThemeScript from '../components/common/ThemeScript.astro';
import Sidebar from '../components/layout/Sidebar.astro';
import DashboardNav from '../components/layout/DashboardNav.astro';
import '../styles/globals.css';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';

interface Props {
  title: string;
  activeNav?: string;
}

const { title, activeNav } = Astro.props;
const siteName = "AIQualityHQ";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="AIQualityHQ" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    
    <title>{title} — {siteName} Dashboard</title>
    <meta name="robots" content="noindex, nofollow" />



    <ThemeScript />
  </head>
  <body class="bg-canvas text-text-primary antialiased min-h-screen flex flex-col md:flex-row">
    <!-- Session Authenticator Gate -->
    <script is:inline>
      (function() {
        const session = localStorage.getItem('user_session');
        if (!session) {
          window.location.href = '/login';
        }
      })();
    </script>

    <!-- Sidebar component -->
    <Sidebar activeNav={activeNav} />

    <!-- Main content frame -->
    <div class="flex-grow flex flex-col pl-16 md:pl-64 transition-all duration-normal min-h-screen bg-canvas">
      <DashboardNav title={title} />
      <main class="flex-grow p-6 md:p-8">
        <slot />
      </main>
    </div>
  </body>
</html>
