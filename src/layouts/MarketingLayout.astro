---
// src/layouts/MarketingLayout.astro
import ThemeScript from '../components/common/ThemeScript.astro';
import TechStackPopup from '../components/ui/TechStackPopup.astro';
import '../styles/globals.css';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  type?: string;
  image?: string;
  noindex?: boolean;
  includeSiteName?: boolean;
}

const { 
  title, 
  description, 
  canonicalUrl = Astro.url.href,
  type = 'website',
  image = 'https://aiqualityhq.com/og-checker.png',
  noindex = false,
  includeSiteName = true
} = Astro.props;

const siteName = "AIQualityHQ";

// Ensure title doesn't duplicate siteName if title already ends with or includes siteName, or if includeSiteName is false
const fullTitle = !includeSiteName || title.includes(siteName) ? title : `${title} — ${siteName}`;

// Ensure canonical URL is always normalized to https://aiqualityhq.com (non-www) and formatted without trailing slashes
const rawCanonical = canonicalUrl || Astro.url.href;
const normalizedDomain = rawCanonical
  .replace('https://www.aiqualityhq.com', 'https://aiqualityhq.com')
  .replace('http://www.aiqualityhq.com', 'https://aiqualityhq.com')
  .replace('http://aiqualityhq.com', 'https://aiqualityhq.com');
const formattedCanonical = (normalizedDomain.endsWith('/') && normalizedDomain !== 'https://aiqualityhq.com/') 
  ? normalizedDomain.slice(0, -1).replace(/\.html$/, '')
  : normalizedDomain.replace(/\.html$/, '');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-adsense-account" content="ca-pub-4836558575831697" />
    
    <!-- Favicons -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="AIQualityHQ" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Google tag (gtag.js) — loaded on first user interaction for performance -->
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-7Z26ZSR7VK');

      (function() {
        let loaded = false;
        function loadGtag() {
          if (loaded) return;
          loaded = true;
          const s = document.createElement('script');
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-7Z26ZSR7VK';
          s.async = true;
          document.head.appendChild(s);
          
          triggerEvents.forEach(e => window.removeEventListener(e, loadGtag, { passive: true }));
        }
        const triggerEvents = ['scroll', 'mousemove', 'touchstart', 'keydown'];
        triggerEvents.forEach(e => window.addEventListener(e, loadGtag, { passive: true }));
      })();
    </script>
    
    <!-- Primary Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <link rel="canonical" href={formattedCanonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={formattedCanonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={siteName} />

    {image && <meta property="og:image" content={image} />}
    {image && <meta name="twitter:image" content={image} />}

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={formattedCanonical} />
    <meta property="twitter:title" content={fullTitle} />
    <meta property="twitter:description" content={description} />





    <!-- CodeMarket Widget Script -->
    <script is:inline src="https://code.market/widget.min.js" async></script>

    <!-- Ahrefs Analytics -->
    <script is:inline src="https://analytics.ahrefs.com/analytics.js" data-key="jl3atvtnDRzKcw7dT/UZrg" async></script>

    <!-- Theme toggling inline script (prevents theme flashing) -->
    <ThemeScript />
  </head>
  <body class="bg-canvas text-text-primary antialiased min-h-screen flex flex-col">
    <slot />
    <TechStackPopup />
  </body>
</html>
