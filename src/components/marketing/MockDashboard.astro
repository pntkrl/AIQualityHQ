---
// src/components/marketing/MockDashboard.astro
import { MessageSquare, Layers, Shield, Lock, Check } from '@lucide/astro';
---

<div class="relative w-full border border-border bg-surface rounded-xl shadow-raised overflow-hidden">
  <!-- Top bar (Simulated browser/window controls) -->
  <div class="flex items-center justify-between px-4 py-3 border-b border-border-subtle bg-surface-secondary">
    <div class="flex items-center gap-1.5">
      <div class="w-3 h-3 rounded-full bg-border-strong opacity-40"></div>
      <div class="w-3 h-3 rounded-full bg-border-strong opacity-40"></div>
      <div class="w-3 h-3 rounded-full bg-border-strong opacity-40"></div>
    </div>
    <div class="text-[11px] font-mono text-text-tertiary select-none">aiqualityhq.com/checker</div>
    <div class="w-12"></div>
  </div>

  <!-- Dashboard Workspace Content -->
  <div class="grid grid-cols-1 lg:grid-cols-12 divide-y lg:divide-y-0 lg:divide-x divide-border-subtle min-h-[500px]">
    <!-- Left Workspace: Input (Prompt Editor) -->
    <div class="lg:col-span-5 p-5 flex flex-col justify-between bg-canvas/30">
      <div class="flex flex-col gap-4">
        <div class="flex items-center justify-between">
          <span class="text-xs font-mono text-primary font-medium tracking-wide uppercase">Workspace / Input</span>
          <span class="text-xs text-text-tertiary">GPT-4o · System Prompt</span>
        </div>
        <div class="border border-border bg-surface p-4 rounded-lg min-h-[220px] font-mono text-xs text-text-secondary leading-relaxed">
          <span class="text-primary font-semibold">system</span> {`<br/>`}
          You are a principal software architect at a scaling fintech startup. Explain microservice saga patterns to a junior engineer.
          {`<br/><br/>`}
          <span class="text-primary font-semibold">user</span> {`<br/>`}
          Explain the database transactions aspect. Give standard code examples. Keep it concise.
        </div>
      </div>
      <div class="flex items-center justify-between mt-4">
        <span class="text-xs text-text-tertiary font-mono">184 characters · 26 words</span>
        <button class="px-4 py-1.5 bg-primary text-text-on-primary rounded text-xs font-medium cursor-default opacity-80" disabled>
          Analyze Prompt
        </button>
      </div>
    </div>

    <!-- Right Workspace: Diagnostic Report -->
    <div class="lg:col-span-7 p-5 flex flex-col gap-6">
      <!-- Title header -->
      <div class="flex items-center justify-between border-b border-border-subtle pb-4">
        <div>
          <h4 class="text-sm font-semibold text-text-primary">Diagnostic Report</h4>
          <p class="text-xs text-text-secondary">Analyzed 12 seconds ago</p>
        </div>
        <div class="inline-flex items-center gap-1 bg-score-excellent-subtle text-score-excellent border border-score-excellent-border rounded-md px-2 py-0.5 text-xs font-mono font-medium">
          Pass
        </div>
      </div>

      <!-- Hero Score & Dimensions -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <!-- Main Score -->
        <div class="md:col-span-1 border-2 border-score-excellent-border bg-surface p-4 rounded-xl flex flex-col justify-center items-center text-center">
          <span class="text-[10px] text-text-secondary uppercase font-semibold tracking-wider mb-1">Quality Score</span>
          <div class="flex items-baseline font-mono">
            <span class="text-4xl font-semibold text-score-excellent tracking-tight">87</span>
            <span class="text-sm text-text-tertiary">/100</span>
          </div>
          <span class="text-[10px] text-score-excellent font-medium mt-1">Strong quality</span>
        </div>

        <!-- Metric Grid -->
        <div class="md:col-span-2 grid grid-cols-2 gap-2">
          <!-- Item 1 -->
          <div class="border border-border-subtle bg-surface-secondary/40 p-2.5 rounded-lg flex items-center gap-2.5">
            <div class="w-8 h-8 rounded bg-score-excellent-subtle text-score-excellent border border-score-excellent-border flex items-center justify-center shrink-0">
              <MessageSquare class="w-4 h-4" />
            </div>
            <div class="flex flex-col">
              <span class="text-[10px] text-text-secondary font-medium">Prompt</span>
              <span class="text-xs font-mono font-semibold text-score-excellent">91/100</span>
            </div>
          </div>
          <!-- Item 2 -->
          <div class="border border-border-subtle bg-surface-secondary/40 p-2.5 rounded-lg flex items-center gap-2.5">
            <div class="w-8 h-8 rounded bg-score-excellent-subtle text-score-excellent border border-score-excellent-border flex items-center justify-center shrink-0">
              <Layers class="w-4 h-4" />
            </div>
            <div class="flex flex-col">
              <span class="text-[10px] text-text-secondary font-medium">Context</span>
              <span class="text-xs font-mono font-semibold text-score-excellent">84/100</span>
            </div>
          </div>
          <!-- Item 3 -->
          <div class="border border-border-subtle bg-surface-secondary/40 p-2.5 rounded-lg flex items-center gap-2.5">
            <div class="w-8 h-8 rounded bg-score-good-subtle text-score-good border border-primary-border flex items-center justify-center shrink-0">
              <Shield class="w-4 h-4" />
            </div>
            <div class="flex flex-col">
              <span class="text-[10px] text-text-secondary font-medium">Trust</span>
              <span class="text-xs font-mono font-semibold text-score-good">78/100</span>
            </div>
          </div>
          <!-- Item 4 -->
          <div class="border border-border-subtle bg-surface-secondary/40 p-2.5 rounded-lg flex items-center gap-2.5">
            <div class="w-8 h-8 rounded bg-score-excellent-subtle text-score-excellent border border-score-excellent-border flex items-center justify-center shrink-0">
              <Lock class="w-4 h-4" />
            </div>
            <div class="flex flex-col">
              <span class="text-[10px] text-text-secondary font-medium">Privacy</span>
              <span class="text-xs font-mono font-semibold text-score-excellent">95/100</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Factor Checks & Recommendations -->
      <div class="flex flex-col gap-3">
        <h5 class="text-xs font-semibold text-text-primary uppercase tracking-wider">Evaluation Factors</h5>
        <div class="flex flex-col gap-2.5 text-xs">
          <div class="flex items-start gap-2 text-text-secondary">
            <div class="w-4 h-4 rounded bg-success-subtle text-success flex items-center justify-center shrink-0 mt-0.5">
              <Check class="w-3 h-3" />
            </div>
            <span>Role constraint successfully defined (Persona: Software Architect).</span>
          </div>
          <div class="flex items-start gap-2 text-text-secondary">
            <div class="w-4 h-4 rounded bg-success-subtle text-success flex items-center justify-center shrink-0 mt-0.5">
              <Check class="w-3 h-3" />
            </div>
            <span>Clear task definition and specific formatting context rules supplied.</span>
          </div>
          <div class="flex items-start gap-2 text-text-secondary">
            <div class="w-4.5 h-4.5 rounded bg-warning-subtle text-warning flex items-center justify-center shrink-0 mt-0.5 font-mono text-[10px] font-bold">
              !
            </div>
            <span class="text-text-primary font-medium">Recommendation: Include code structure constraint (e.g. specify programming language frameworks).</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
