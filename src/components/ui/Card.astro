---
// src/components/ui/Card.astro
interface Props {
  radius?: 'lg' | 'xl' | '2xl';
  elevation?: 'flat' | 'subtle' | 'raised' | 'floating';
  interactive?: boolean;
  class?: string;
  [key: string]: any;
}

const {
  radius = 'xl',
  elevation = 'flat',
  interactive = false,
  class: customClass = '',
  ...rest
} = Astro.props;

const baseStyles = 'bg-surface border border-border transition-all duration-fast';

const radii = {
  lg: 'rounded-lg',
  xl: 'rounded-xl',
  '2xl': 'rounded-2xl',
};

const elevations = {
  flat: 'shadow-none',
  subtle: 'shadow-subtle',
  raised: 'shadow-raised',
  floating: 'shadow-floating',
};

const interactiveStyles = interactive 
  ? 'hover:border-border-strong hover:shadow-subtle cursor-pointer active:bg-surface-secondary' 
  : '';

const radiusClass = radii[radius] || radii.xl;
const elevationClass = elevations[elevation] || elevations.flat;
---
<div
  class:list={[baseStyles, radiusClass, elevationClass, interactiveStyles, customClass]}
  {...rest}
>
  <slot />
</div>
