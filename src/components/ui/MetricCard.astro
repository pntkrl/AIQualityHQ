---
// src/components/ui/MetricCard.astro
interface Props {
  label: string;
  value: string | number;
  sublabel?: string;
  class?: string;
}

const { label, value, sublabel, class: customClass = '' } = Astro.props;
---
<div class:list={["bg-surface border border-border rounded-lg p-4 flex flex-col justify-between h-[100px] select-none", customClass]}>
  <span class="text-[10px] font-mono font-semibold uppercase tracking-wider text-text-secondary">
    {label}
  </span>
  <span class="text-2xl font-semibold tracking-tight text-text-primary mt-1 select-all font-mono tabular-nums leading-none">
    {value}
  </span>
  {sublabel && (
    <span class="text-[10px] text-text-tertiary mt-1.5 truncate">
      {sublabel}
    </span>
  )}
</div>
