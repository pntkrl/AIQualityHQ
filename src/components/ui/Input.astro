---
// src/components/ui/Input.astro
interface Props {
  type?: 'text' | 'email' | 'password' | 'number' | 'search' | 'url' | 'tel';
  name?: string;
  value?: string;
  placeholder?: string;
  required?: boolean;
  disabled?: boolean;
  class?: string;
  [key: string]: any;
}

const {
  type = 'text',
  name,
  value,
  placeholder,
  required = false,
  disabled = false,
  class: customClass = '',
  ...rest
} = Astro.props;

const baseStyles = 'w-full bg-surface border border-border rounded-md text-sm px-3 h-9 transition-default placeholder:text-text-tertiary disabled:opacity-disabled disabled:pointer-events-none focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary';
---
<input
  type={type}
  name={name}
  value={value}
  placeholder={placeholder}
  required={required}
  disabled={disabled}
  class:list={[baseStyles, customClass]}
  {...rest}
/>
