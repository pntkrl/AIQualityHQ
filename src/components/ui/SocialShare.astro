---
// src/components/ui/SocialShare.astro
import { Share2, Link, Check } from '@lucide/astro';

interface Props {
  url?: string;
  title?: string;
  description?: string;
  class?: string;
}

const { 
  url = '', 
  title = '', 
  description = '',
  class: customClass = ''
} = Astro.props;
---

<div 
  class={`social-share-container border border-border bg-surface/50 backdrop-blur-sm rounded-xl p-5 flex flex-col sm:flex-row sm:items-center justify-between gap-4 font-sans w-full max-w-[800px] mx-auto ${customClass}`}
  data-url={url}
  data-title={title}
  data-desc={description}
>
  <div class="flex items-center gap-3">
    <div class="w-9 h-9 rounded-full bg-primary/10 text-primary flex items-center justify-center shrink-0">
      <Share2 class="w-4.5 h-4.5" />
    </div>
    <div>
      <h3 class="text-sm font-semibold text-text-primary leading-tight">Share with your network</h3>
      <p class="text-xs text-text-secondary mt-0.5 leading-relaxed">
        Help other engineers build reliable, secure, and precise AI prompts.
      </p>
    </div>
  </div>
  
  <div class="flex items-center gap-2 flex-wrap">
    <button 
      class="share-btn share-x px-3 py-1.5 border border-border bg-surface text-text-secondary hover:text-text-primary hover:bg-surface-secondary text-xs font-medium rounded-md transition-all duration-200 flex items-center gap-1.5 cursor-pointer select-none" 
      aria-label="Share on X"
    >
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
      <span>X</span>
    </button>
    
    <button 
      class="share-btn share-linkedin px-3 py-1.5 border border-border bg-surface text-text-secondary hover:text-[#0A66C2] hover:border-[#0A66C2]/30 hover:bg-[#0A66C2]/5 text-xs font-medium rounded-md transition-all duration-200 flex items-center gap-1.5 cursor-pointer select-none" 
      aria-label="Share on LinkedIn"
    >
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
      <span>LinkedIn</span>
    </button>
    
    <button 
      class="share-btn share-facebook px-3 py-1.5 border border-border bg-surface text-text-secondary hover:text-[#1877F2] hover:border-[#1877F2]/30 hover:bg-[#1877F2]/5 text-xs font-medium rounded-md transition-all duration-200 flex items-center gap-1.5 cursor-pointer select-none" 
      aria-label="Share on Facebook"
    >
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
      </svg>
      <span>Facebook</span>
    </button>
    
    <button 
      class="share-btn share-copy px-3 py-1.5 border border-border bg-surface text-text-secondary hover:text-primary hover:border-primary-border hover:bg-primary-subtle text-xs font-medium rounded-md transition-all duration-200 flex items-center gap-1.5 cursor-pointer select-none" 
      aria-label="Copy page link"
    >
      <Link class="w-3.5 h-3.5 icon-link text-text-tertiary" />
      <Check class="w-3.5 h-3.5 icon-check hidden text-primary" />
      <span class="copy-text">Copy Link</span>
    </button>
  </div>
</div>

<script>
  // Handle share interactions on the client side
  function initShareButtons() {
    document.querySelectorAll('.social-share-container').forEach(container => {
      // Avoid duplicate event listener binding
      if (container.getAttribute('data-share-initialized') === 'true') return;
      container.setAttribute('data-share-initialized', 'true');

      const defaultUrl = window.location.href;
      const defaultTitle = document.title;
      
      const url = container.getAttribute('data-url') || defaultUrl;
      const title = container.getAttribute('data-title') || defaultTitle;
      
      // X / Twitter
      const xBtn = container.querySelector('.share-x');
      if (xBtn) {
        xBtn.addEventListener('click', () => {
          const shareText = `${title} — Check out AIQualityHQ:`;
          window.open(
            `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(url)}`, 
            '_blank', 
            'width=600,height=400,noopener,noreferrer'
          );
        });
      }
      
      // LinkedIn
      const liBtn = container.querySelector('.share-linkedin');
      if (liBtn) {
        liBtn.addEventListener('click', () => {
          window.open(
            `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`, 
            '_blank', 
            'width=600,height=600,noopener,noreferrer'
          );
        });
      }
      
      // Facebook
      const fbBtn = container.querySelector('.share-facebook');
      if (fbBtn) {
        fbBtn.addEventListener('click', () => {
          window.open(
            `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`, 
            '_blank', 
            'width=600,height=500,noopener,noreferrer'
          );
        });
      }
      
      // Copy Link
      const copyBtn = container.querySelector('.share-copy');
      if (copyBtn) {
        const linkIcon = copyBtn.querySelector('.icon-link');
        const checkIcon = copyBtn.querySelector('.icon-check');
        const copyText = copyBtn.querySelector('.copy-text');
        
        copyBtn.addEventListener('click', () => {
          navigator.clipboard.writeText(url).then(() => {
            if (linkIcon && checkIcon && copyText) {
              linkIcon.classList.add('hidden');
              checkIcon.classList.remove('hidden');
              copyText.textContent = 'Copied!';
              
              setTimeout(() => {
                linkIcon.classList.remove('hidden');
                checkIcon.classList.add('hidden');
                copyText.textContent = 'Copy Link';
              }, 2000);
            }
          });
        });
      }
    });
  }

  // Init on load and layout changes (e.g. view transition switches if enabled)
  initShareButtons();
  document.addEventListener('astro:page-load', initShareButtons);
</script>
