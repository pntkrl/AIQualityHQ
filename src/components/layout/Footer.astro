---
// src/components/layout/Footer.astro
const currentYear = new Date().getFullYear();
---
<footer class="w-full bg-canvas border-t border-border-subtle pt-16 pb-8 transition-fast mt-auto">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">
      <!-- Col 1: Brand -->
      <div class="flex flex-col gap-3">
        <span class="flex items-center gap-2 font-sans font-semibold text-lg tracking-tight text-text-primary">
          <img src="/favicon-96x96.png" alt="" class="w-6 h-6 shrink-0" width="24" height="24" />
          <span>AIQuality<span class="text-primary">HQ</span></span>
        </span>
        <p class="text-xs text-text-secondary max-w-[200px] leading-relaxed font-sans">
          Help people measure, improve, and trust every AI interaction.
        </p>
      </div>

      <!-- Col 2: Product -->
      <div>
        <h3 class="text-xs font-semibold text-text-primary mb-4 uppercase tracking-wider">Product</h3>
        <ul class="flex flex-col gap-2">
          <li><a href="/checker" class="text-xs text-text-secondary hover:text-text-primary transition-fast">Prompt Checker</a></li>
          <li><a href="/#features" class="text-xs text-text-secondary hover:text-text-primary transition-fast">Quality Engine</a></li>
        </ul>
      </div>

      <!-- Col 3: Resources -->
      <div>
        <h3 class="text-xs font-semibold text-text-primary mb-4 uppercase tracking-wider">Resources</h3>
        <ul class="flex flex-col gap-2">
          <li><a href="/about" class="text-xs text-text-secondary hover:text-text-primary transition-fast">About Us</a></li>
          <li><a href="/docs" class="text-xs text-text-secondary hover:text-text-primary transition-fast">Documentation</a></li>
          <li><a href="/faq" class="text-xs text-text-secondary hover:text-text-primary transition-fast">FAQ</a></li>
          <li><a href="/#dimensions" class="text-xs text-text-secondary hover:text-text-primary transition-fast">Quality Dimensions</a></li>
          <li><a href="/sitemap.xml" class="text-xs text-text-secondary hover:text-text-primary transition-fast">Sitemap</a></li>
        </ul>
      </div>


      <!-- Col 4: Legal -->
      <div>
        <h3 class="text-xs font-semibold text-text-primary mb-4 uppercase tracking-wider">Legal</h3>
        <ul class="flex flex-col gap-2">
          <li><a href="/privacy" class="text-xs text-text-secondary hover:text-text-primary transition-fast">Privacy Policy</a></li>
          <li><a href="/terms" class="text-xs text-text-secondary hover:text-text-primary transition-fast">Terms of Service</a></li>
          <li><a href="/contact" class="text-xs text-text-secondary hover:text-text-primary transition-fast">Contact Us</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom strip -->
    <div class="border-t border-border-subtle mt-12 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <span class="text-xs text-text-tertiary">
        &copy; {currentYear} AIQualityHQ. All rights reserved.
      </span>
      <span class="text-xs text-text-tertiary flex items-center gap-1 font-sans">
        Designed for trust and precision.
      </span>
    </div>
  </div>
</footer>
