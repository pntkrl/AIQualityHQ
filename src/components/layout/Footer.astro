---
// src/components/layout/Footer.astro
const currentYear = new Date().getFullYear();
---
<footer class="w-full bg-canvas border-t border-border-subtle pt-16 pb-8 transition-fast mt-auto">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">
      <!-- Col 1: Brand -->
      <div class="flex flex-col gap-3">
        <span class="flex items-center gap-2 font-sans font-semibold text-lg tracking-tight text-text-primary">
          <img src="/aiqualityhq-logo.svg" alt="AIQualityHQ Logo" class="w-6 h-6 shrink-0" width="24" height="24" />
          <span>AIQuality<span class="text-primary">HQ</span></span>
        </span>
        <p class="text-xs text-text-secondary max-w-[200px] leading-relaxed font-sans">
          Help people measure, improve, and trust every AI interaction.
        </p>
      </div>

      <!-- Col 2: Product -->
      <div>
        <h3 class="text-xs font-semibold text-text-primary mb-4 uppercase tracking-wider">Product</h3>
        <ul class="flex flex-col gap-2">
          <li><a href="/checker" class="text-xs text-text-secondary hover:text-text-primary transition-fast">Prompt Checker</a></li>
          <li><a href="/ai-audit" class="text-xs text-text-secondary hover:text-text-primary transition-fast">AI Auditor tool</a></li>
        </ul>
      </div>

      <!-- Col 3: Resources -->
      <div>
        <h3 class="text-xs font-semibold text-text-primary mb-4 uppercase tracking-wider">Resources</h3>
        <ul class="flex flex-col gap-2">
          <li><a href="/about" class="text-xs text-text-secondary hover:text-text-primary transition-fast">About Us</a></li>
          <li><a href="/docs" class="text-xs text-text-secondary hover:text-text-primary transition-fast">Documentation</a></li>
          <li><a href="/articles" class="text-xs text-text-secondary hover:text-text-primary transition-fast">Articles & Guides</a></li>
          <li><a href="/faq" class="text-xs text-text-secondary hover:text-text-primary transition-fast">FAQ</a></li>
          <li><a href="/#dimensions" class="text-xs text-text-secondary hover:text-text-primary transition-fast">Quality Dimensions</a></li>
          <li><a href="/partners" class="text-xs text-text-secondary hover:text-text-primary transition-fast">Partners & Tools</a></li>
          <li><a href="/sitemap.xml" class="text-xs text-text-secondary hover:text-text-primary transition-fast">Sitemap</a></li>
        </ul>
      </div>


      <!-- Col 4: Legal -->
      <div>
        <h3 class="text-xs font-semibold text-text-primary mb-4 uppercase tracking-wider">Legal</h3>
        <ul class="flex flex-col gap-2">
          <li><a href="/privacy" class="text-xs text-text-secondary hover:text-text-primary transition-fast">Privacy Policy</a></li>
          <li><a href="/terms" class="text-xs text-text-secondary hover:text-text-primary transition-fast">Terms of Service</a></li>
          <li><a href="/contact" class="text-xs text-text-secondary hover:text-text-primary transition-fast">Contact Us</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom strip -->
    <div class="border-t border-border-subtle mt-12 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <span class="text-xs text-text-tertiary">
        &copy; {currentYear} AIQualityHQ. All rights reserved.
      </span>
      <span class="text-xs text-text-tertiary flex items-center gap-3 font-sans select-none">
        <span>Designed for trust and precision.</span>
        <span class="text-text-disabled">|</span>
        <span class="text-[11px] text-text-tertiary">Share AIQualityHQ:</span>
        <a 
          href="https://twitter.com/intent/tweet?text=Check%20out%20AIQualityHQ%20%E2%80%94%20a%20free%20tool%20to%20measure%2C%20improve%2C%20and%20trust%20every%20AI%20prompt%20interaction%21&url=https%3A%2F%2Faiqualityhq.com" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="hover:text-text-primary transition-fast"
          title="Share on X"
        >
          X
        </a>
        <a 
          href="https://www.linkedin.com/sharing/share-offsite/?url=https%3A%2F%2Faiqualityhq.com" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="hover:text-text-primary transition-fast"
          title="Share on LinkedIn"
        >
          LinkedIn
        </a>
        <a 
          href="https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Faiqualityhq.com" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="hover:text-text-primary transition-fast"
          title="Share on Facebook"
        >
          Facebook
        </a>
      </span>
    </div>

    
      <!-- Badges Row -->
    <div class="border-t border-border-subtle mt-8 pt-8 flex flex-wrap items-center justify-center gap-x-8 gap-y-6">
      <a href="https://toolhunter.ai/ai-tool/aiqualityhq?ref=badge" target="_blank" rel="noopener">
        <img src="https://toolhunter.ai/badge/aiqualityhq.svg?theme=light" alt="Featured on Toolhunter" width="140" height="35" class="h-8 w-auto object-contain" />
      </a>
      <a href="https://www.futurestore.ai/" target="_blank" rel="noopener noreferrer" data-futurestoreai-badge="verified">
        <img src="https://futurestore.ai/light_logo.png" alt="Listed on FutureStore" width="100" height="32" class="h-8 w-auto object-contain" />
      </a>
      <a href="https://submitaitools.org" target="_blank">
        <img src="https://submitaitools.org/static_submitaitools/images/submitaitools.png" alt="Submit AI Tools" width="107" height="32" class="h-8 w-auto object-contain rounded" />
      </a>
      <a href="https://www.tooljunction.io" target="_blank" rel="noopener noreferrer">
        <img src="https://ik.imagekit.io/or8e5hp54/tj/badge.svg" alt="Featured on ToolJunction" width="107" height="32" class="h-8 w-auto object-contain" />
      </a>
      <a href="https://dang.ai" target="_blank" rel="dofollow noopener" style="display:inline-block;text-decoration:none;">
        <img src="https://assets.dang.ai/badges/dang-verified-dark.png" alt="Verified on DANG!" width="88" height="32" class="h-8 w-auto object-contain" style="border:0;outline:none;" />
      </a>
      <a href="https://showmebest.ai" target="_blank">
        <img src="https://showmebest.ai/badge/feature-badge-white.webp" alt="Featured on ShowMeBestAI" width="117" height="32" class="h-8 w-auto object-contain" />
      </a>
      <a href="https://aiagentsdirectory.com/agent/aiqualityhq" target="_blank" rel="noopener" title="Discover AIQualityHQ on AI Agents Directory">
        <img src="https://aiagentsdirectory.com/featured-badge.svg?v=2024" alt="AIQualityHQ - Featured on AI Agents Directory" width="128" height="32" class="h-8 w-auto object-contain" />
      </a>
      <a target="_blank" href="https://acidtools.com/ai/aiqualityhq">
        <img src="https://acidtools.com/assets/images/badge.png" alt="Acid Tools" width="88" height="32" class="h-8 w-auto object-contain" loading="lazy" />
      </a>
      <a target="_blank" href="https://apphublist.com/products/aiqualityhq">
        <img src="https://apphublist.com/assets/images/badge.png" alt="App Hub List" width="88" height="32" class="h-8 w-auto object-contain" loading="lazy" />
      </a>
      <a target="_blank" href="https://aixcollection.com/ai/aiqualityhq">
        <img src="https://aixcollection.com/assets/images/badge.png" alt="AI X Collection" height="54" class="h-8 w-auto object-contain" loading="lazy" />
      </a>
      <a target="_blank" href="https://aitechviral.com/ai/aiqualityhq">
        <img src="https://aitechviral.com/assets/images/badge.png" alt="AI Tech Viral" height="54" class="h-8 w-auto object-contain" loading="lazy" />
      </a>
      <a target="_blank" href="https://appalist.com/ai/aiqualityhq">
        <img src="https://appalist.com/assets/images/badge.png" alt="Appa List" height="54" class="h-8 w-auto object-contain" loading="lazy" />
      </a>
      <a target="_blank" href="https://saasfield.com/ai/aiqualityhq">
        <img src="https://saasfield.com/assets/images/badge.png" alt="SaaS Field" height="54" class="h-8 w-auto object-contain" loading="lazy" />
      </a>
      <a target="_blank" href="https://aitoolzs.com/ai/aiqualityhq">
        <img src="https://aitoolzs.com/assets/images/badge.png" alt="AI Toolz" height="54" class="h-8 w-auto object-contain" loading="lazy" />
      </a>
      <a target="_blank" href="https://poweruptools.com/ai/aiqualityhq">
        <img src="https://poweruptools.com/assets/images/badge.png" alt="Power Up Tools" height="54" class="h-8 w-auto object-contain" loading="lazy" />
      </a>
      <div
        data-codemarket-widget="free-ai-prompt-quality-checker-aiqualityhq"
        data-theme-bg="#ffffff"
        data-theme-text="slate-600"
        data-layout="grid"
        data-show-branding="false"
      ></div>
    </div>
  </div>
</footer>
